{layout layouts/main.latte}

{block title}Immunity, decentralized threat intelligence for AI agents{/block}

{block head}
<script defer src="/assets/js/propagation-map.js"></script>
<script>
window.addEventListener('DOMContentLoaded', () => {
  const el = document.getElementById('prop-map');
  if (el && window.PropagationMap) new window.PropagationMap(el);
});
</script>
{/block}

{block content}

{* ============================================================ HERO ===== *}
<section class="relative">
    <div class="absolute inset-0 dot-bg opacity-60 pointer-events-none"></div>
    <div class="absolute inset-x-0 top-0 h-[420px] vignette-radial pointer-events-none"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 pt-24 pb-20">

        {* Eyebrow *}
        <div class="flex items-center gap-3 mb-8">
            <span class="inline-flex items-center gap-2 font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">
                <span class="inline-flex h-1.5 w-1.5 rounded-full bg-accent pulse-soft"></span>
                Live network / mock data
            </span>
            <span class="h-px w-10 bg-ink-line"></span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-dim">v0.1.0</span>
        </div>

        {* Headline *}
        <h1 class="font-display display-xl font-light tracking-tightest text-fg-primary text-[64px] sm:text-[80px] md:text-[104px] leading-[0.92] mb-10 max-w-[1080px]">
            Decentralized threat<br>intelligence for
            <span class="italic font-light text-accent">AI agents</span>.
        </h1>

        {* Lede *}
        <p class="text-fg-secondary text-[17px] leading-[1.65] max-w-[560px] mb-12">
            When one agent encounters a malicious actor, every other agent learns within seconds. Antibodies are signed by their publisher, staked on chain, and globally addressable by a stable CVE-style identifier.
        </p>

        {* CTAs *}
        <div class="flex flex-wrap items-center gap-3">
            <a href="/antibodies" class="group inline-flex items-center gap-2 px-5 py-3 text-[13px] tracking-wide bg-fg-primary text-ink-base hover:bg-accent transition-colors rounded-sm">
                Explore antibodies
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="opacity-60 group-hover:translate-x-0.5 transition-transform"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/dashboard" class="inline-flex items-center gap-2 px-5 py-3 text-[13px] tracking-wide border border-ink-line text-fg-secondary hover:text-fg-primary hover:border-fg-tertiary transition-colors rounded-sm">
                View live dashboard
            </a>
            <span class="ml-2 text-[12px] text-fg-tertiary font-mono">
                or read the <a href="https://docs.immunity.xyz" rel="noopener" class="text-fg-secondary hover:text-fg-primary underline underline-offset-4 decoration-fg-dim">protocol brief</a>
            </span>
        </div>

    </div>
</section>

{* ================================================== PROPAGATION MAP ===== *}
<section class="relative border-y border-ink-line/70 bg-ink-sunken/40">
    <div class="absolute inset-0 grid-bg opacity-30 pointer-events-none"></div>
    <div class="relative max-w-[1400px] mx-auto px-7 py-16">
        <div class="flex items-end justify-between mb-8">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Network</span>
                    <span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
                </div>
                <h2 class="font-display text-[28px] font-light tracking-tighter text-fg-primary">
                    60 agents, gossiping antibodies in real time
                </h2>
            </div>
            <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary text-right">
                <div>Tip: click a node to take it offline</div>
                <div class="text-fg-dim">propagation continues regardless</div>
            </div>
        </div>

        <div id="prop-map" class="w-full max-w-[760px] mx-auto aspect-square"></div>
    </div>
</section>

{* ====================================================== STAT STRIP ===== *}
<section class="border-y border-ink-line/70 bg-ink-sunken/60 relative">
    <div class="absolute inset-0 dot-bg opacity-30 pointer-events-none"></div>
    <div class="relative max-w-[1400px] mx-auto px-7 py-10 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-y-10 md:gap-0">

        {* Antibodies active *}
        <div class="md:px-7 md:first:pl-0 md:border-r md:border-ink-line/60 md:last:border-r-0 md:last:pr-0">
            <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3 flex items-center gap-2">
                <span>Antibodies active</span>
                <span class="inline-flex h-1 w-1 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
            </div>
            <div class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">312</div>
            <div class="font-mono text-[11px] text-immune-500 mt-3 inline-flex items-center gap-1.5">
                <svg width="9" height="9" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 8l4-4 4 4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                +14 in 1h
            </div>
        </div>

        {* Agents online *}
        <div class="md:px-7 md:border-r md:border-ink-line/60">
            <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Agents online</div>
            <div class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">1,247</div>
            <div class="font-mono text-[11px] text-immune-500 mt-3 inline-flex items-center gap-1.5">
                <svg width="9" height="9" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 8l4-4 4 4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                +8 in 1h
            </div>
        </div>

        {* Cache hits / hour *}
        <div class="md:px-7 md:border-r md:border-ink-line/60">
            <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Cache hits / hr</div>
            <div class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">18,492</div>
            <div class="font-mono text-[11px] text-fg-tertiary mt-3">
                avg 5.1 / agent
            </div>
        </div>

        {* LLM calls saved *}
        <div class="md:px-7 md:border-r md:border-ink-line/60">
            <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">LLM calls saved</div>
            <div class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">4,217</div>
            <div class="font-mono text-[11px] text-fg-tertiary mt-3">
                <span class="text-immune-500">≈ $8,920</span> in compute
            </div>
        </div>

        {* Value protected *}
        <div class="md:px-7 md:last:pr-0">
            <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Value protected</div>
            <div class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">$248,300</div>
            <div class="font-mono text-[11px] text-immune-500 mt-3 inline-flex items-center gap-1.5">
                <svg width="9" height="9" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 8l4-4 4 4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                +$4,200 in 1h
            </div>
        </div>

    </div>
</section>

{* ===================================================== LIVE FEED ===== *}
<section class="relative">
    <div class="max-w-[1400px] mx-auto px-7 pt-20 pb-12">

        <div class="flex items-end justify-between mb-7">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Live activity</span>
                    <span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
                </div>
                <h2 class="font-display text-[28px] font-light tracking-tighter text-fg-primary">
                    Recent mints, blocks, challenges
                </h2>
            </div>
            <a href="/dashboard" class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary hover:text-fg-primary transition-colors inline-flex items-center gap-1.5">
