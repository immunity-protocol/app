            </a>

            {* ======== row 4: mint ======== *}
            <a href="/antibody/IMM-2026-0298" class="grid grid-cols-[14px_64px_148px_118px_1fr_200px] gap-4 items-center py-3.5 border-b border-ink-line/40 hover:bg-ink-elevated/40 transition-colors group">
                <span class="inline-flex h-1.5 w-1.5 rounded-full bg-accent" aria-label="mint"></span>
                <span class="font-mono text-[11px] text-fg-tertiary tabular-nums">2m ago</span>
                <span class="font-mono text-[12px] text-fg-primary group-hover:text-accent transition-colors">IMM-2026-0298</span>
                <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">minted</span>
