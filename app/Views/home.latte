{layout layouts/main.latte}

{block title}Immunity, decentralized threat intelligence for AI agents{/block}

{block head}
<script>
window.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('[data-copy-btn]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-copy-btn');
      const text = btn.getAttribute('data-copy-value') || (document.querySelector(target)?.innerText ?? '');
      navigator.clipboard?.writeText(text);
      const label = btn.querySelector('[data-copy-label]');
      if (label) {
        const prev = label.innerText;
        label.innerText = 'Copied';
        btn.classList.add('copy-flash');
        setTimeout(() => { label.innerText = prev; btn.classList.remove('copy-flash'); }, 1400);
      }
    });
  });
});
</script>
{/block}

{block content}

{* ============================================================ HERO ===== *}
<section class="relative overflow-hidden bg-ink-base">

    {* Ambient video, hidden on mobile to save bandwidth *}
    <video class="hero-video absolute inset-0 w-full h-full object-cover hidden md:block pointer-events-none"
           autoplay muted loop playsinline preload="metadata"
           poster="{asset('/assets/videos/hero-aqua-poster.jpg')}"
           aria-hidden="true">
        <source src="{asset('/assets/videos/hero-aqua.mp4')}" type="video/mp4">
    </video>

    {* Mobile / reduced-motion fallback: poster as static image *}
    <img class="hero-poster absolute inset-0 w-full h-full object-cover md:hidden pointer-events-none"
         src="{asset('/assets/videos/hero-aqua-poster.jpg')}" alt="" aria-hidden="true">

    {* Left-side legibility gradient *}
    <div class="absolute inset-0 bg-gradient-to-r from-ink-base from-30% via-ink-base/80 via-50% to-transparent to-100% pointer-events-none" aria-hidden="true"></div>

    {* Bottom fade-to-dark, soft blend into the next section *}
    <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-b from-transparent via-ink-base/80 via-60% to-ink-base pointer-events-none" aria-hidden="true"></div>

    {* Subtle grain so the video doesn't read as a stock-footage embed *}
    <div class="absolute inset-0 dot-bg opacity-50 pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 pt-20 pb-24 min-h-screen flex flex-col justify-center">

        {* Big hero brand block. Cross-fades to the small nav brand on scroll
           via #hero-brand / #nav-brand opacity rules in app.css. *}
        <div id="hero-brand" class="hero-brand absolute top-7 left-7 flex items-center gap-4 origin-left pointer-events-none select-none" aria-hidden="true">
            <span class="block h-[88px] w-[88px] bg-fg-primary"
                  style="-webkit-mask: url(/assets/images/immunity-mark.png) center/contain no-repeat; mask: url(/assets/images/immunity-mark.png) center/contain no-repeat;"></span>
            <span class="font-display text-[56px] font-light tracking-tighter text-fg-primary leading-none">Immunity</span>
        </div>

        {* Headline, two stanzas: the technical claim, then the philosophy *}
        <h1 class="font-display display-xl font-light tracking-tightest text-fg-primary text-[44px] sm:text-[60px] md:text-[78px] leading-[1.0] mb-9 max-w-[1100px]">
            <span class="block">Decentralized threat intelligence</span>
            <span class="block">for AI agents. An attack on one</span>
            <span class="block">is a <span class="italic font-light text-accent">vaccine for all</span>.</span>
        </h1>

        {* Lede *}
        <p class="text-fg-secondary text-[18px] leading-[1.6] max-w-[640px] mb-10">
            Antibodies are signed by their publisher, staked on chain, and addressable by a stable CVE-style identifier. Cheap matches resolve locally in microseconds. Novel threats verify in a 0G Compute TEE. The network is the immune system.
        </p>

        {* Install command block, the centerpiece *}
        <div class="max-w-[640px] mb-7">
            <div class="group relative flex items-stretch border border-ink-line/80 rounded-sm bg-ink-elevated/60 backdrop-blur-sm hover:border-fg-tertiary transition-colors overflow-hidden">
                <span class="inline-flex items-center px-4 py-3.5 font-mono text-[12px] text-fg-dim border-r border-ink-line/60 select-none" aria-hidden="true">$</span>
                <code id="install-cmd" class="flex-1 px-4 py-3.5 font-mono text-[14.5px] text-fg-primary bg-transparent overflow-x-auto whitespace-nowrap">npm install @immunity-protocol/sdk</code>
                <button data-copy-btn="#install-cmd" data-copy-value="npm install @immunity-protocol/sdk"
                        class="inline-flex items-center gap-2 px-4 py-3.5 border-l border-ink-line/60 text-fg-tertiary hover:text-accent hover:bg-ink-elevated transition-colors font-mono text-[10.5px] uppercase tracking-widest2"
                        aria-label="Copy install command">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                    <span data-copy-label>Copy</span>
                </button>
            </div>
            <p class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-dim mt-2.5">
                Chain agnostic.
            </p>
        </div>

        {* CTAs *}
        <div class="flex flex-wrap items-center gap-3">
            <a href="https://docs.immunity.xyz" rel="noopener" class="group inline-flex items-center gap-2 px-5 py-3 text-[13px] tracking-wide bg-fg-primary text-ink-base hover:bg-accent transition-colors rounded-sm">
                Read the protocol
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="opacity-60 group-hover:translate-x-0.5 transition-transform" aria-hidden="true"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/dashboard" class="group inline-flex items-center gap-2 px-5 py-3 text-[13px] tracking-wide border border-ink-line text-fg-secondary hover:text-fg-primary hover:border-fg-tertiary transition-colors rounded-sm">
                View live dashboard
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="opacity-50 group-hover:translate-x-0.5 transition-transform" aria-hidden="true"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
        </div>

    </div>
</section>

{* ============================================ 01 · NETWORK STATUS ===== *}
<section class="relative bg-ink-sunken border-b border-ink-line/60">
    <div class="absolute inset-0 grid-bg opacity-20 pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 py-12">

        <div class="flex items-center gap-3 mb-7">
            <span class="font-mono text-[10.5px] text-fg-tertiary tabular-nums">01</span>
            <span class="font-mono text-[10.5px] text-fg-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Network status</span>
            <span id="live-pulse" class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
            <span id="live-label" class="font-mono text-[10.5px] uppercase tracking-widest2 text-immune-500">Live</span>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-4 gap-y-10 md:gap-0">

            <div class="md:px-7 md:first:pl-0 md:border-r md:border-ink-line/60 md:last:border-r-0 md:last:pr-0">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3 flex items-center gap-2">
                    <span>Antibodies active</span>
                    <span class="inline-flex h-1 w-1 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
                </div>
                <div data-stat="antibodies_active" class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">312</div>
                <div class="font-mono text-[11px] text-immune-500 mt-3 inline-flex items-center gap-1.5">
                    <svg width="9" height="9" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 8l4-4 4 4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span data-delta="antibodies_active">+14 in 1h</span>
                </div>
            </div>

            <div class="md:px-7 md:border-r md:border-ink-line/60">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Cache hits / hr</div>
                <div data-stat="cache_hits_per_hour" class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">18,492</div>
                <div class="font-mono text-[11px] text-immune-500 mt-3 inline-flex items-center gap-1.5">
                    <svg width="9" height="9" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 8l4-4 4 4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span data-delta="cache_hits_per_hour">+0 in 1h</span>
                </div>
            </div>

            <div class="md:px-7 md:border-r md:border-ink-line/60">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">LLM calls saved</div>
                <div data-stat="llm_calls_saved" class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">4,217</div>
                <div class="font-mono text-[11px] text-fg-tertiary mt-3">
                    <span class="text-immune-500" data-compute-saved="llm_calls_saved">≈ $0.42</span> in compute
                </div>
            </div>

            <div class="md:px-7 md:last:pr-0">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Value protected</div>
                <div data-stat-money="value_protected_usd" class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">$248,300</div>
                <div class="font-mono text-[11px] text-immune-500 mt-3 inline-flex items-center gap-1.5">
                    <svg width="9" height="9" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 8l4-4 4 4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span data-delta-money="value_protected_usd">+$4,200 in 1h</span>
                </div>
            </div>

        </div>
    </div>
</section>

{* ============================================ 02 · HOW IT WORKS ===== *}
<section class="relative bg-cream-base text-parch-primary">
    <div class="absolute inset-0 dot-bg-light opacity-60 pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 py-24">

        <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[10.5px] text-parch-tertiary tabular-nums">02</span>
            <span class="font-mono text-[10.5px] text-parch-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-parch-tertiary">How it works</span>
        </div>
        <h2 class="font-display text-[40px] font-light tracking-tighter leading-[1.05] mb-4 max-w-[720px]">
            From threat to immunity in 30 seconds.
        </h2>
        <p class="text-parch-secondary text-[15.5px] leading-[1.65] max-w-[640px] mb-14">
            One protocol, four steps, and the network is more resilient than it was a minute ago. No human in the loop.
        </p>

        {var $steps = [
          ['n' => '01', 'title' => 'Agent encounters a threat',
           'body' => 'An AI agent receives a suspicious tx, scraped content, or counterparty message and calls check() before acting.',
           'icon' => 'cell-alert'],
          ['n' => '02', 'title' => 'Detection runs in a TEE',
           'body' => 'Encrypted context goes to a 0G Compute enclave running qwen-2.5-7b. Verdict comes back signed with attestation.',
           'icon' => 'enclave'],
          ['n' => '03', 'title' => 'Antibody is minted and propagated',
           'body' => 'The publisher locks 1 USDC for 72h. The antibody hits 0G Chain for settlement and gossips across the AXL mesh.',
           'icon' => 'radiate'],
          ['n' => '04', 'title' => 'Every other agent is now immune',
           'body' => 'Local caches update in under a second. The same attack is blocked everywhere — by SDK on agents, by hook on Uniswap pools.',
           'icon' => 'mesh'],
        ]}

        <div class="relative grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-cream-line">
            {foreach $steps as $i => $s}
                <article class="relative bg-cream-base hover:bg-cream-elevated transition-colors p-7 group">

                    {* Icon *}
                    <div class="mb-6">
                        {if $s['icon'] === 'cell-alert'}
                            <svg width="36" height="36" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" class="text-parch-primary" aria-hidden="true"><circle cx="20" cy="24" r="11"/><circle cx="20" cy="24" r="3" fill="currentColor"/><path d="M36 12v10M36 28v0.5" stroke-linecap="round" stroke-width="2"/></svg>
                        {elseif $s['icon'] === 'enclave'}
                            <svg width="36" height="36" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" class="text-parch-primary" aria-hidden="true"><rect x="8" y="20" width="32" height="20" rx="2"/><path d="M14 20v-6a10 10 0 0 1 20 0v6"/><circle cx="24" cy="30" r="2.5"/></svg>
                        {elseif $s['icon'] === 'radiate'}
                            <svg width="36" height="36" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" class="text-parch-primary" aria-hidden="true"><circle cx="24" cy="24" r="3" fill="currentColor"/><circle cx="24" cy="24" r="9" opacity="0.65"/><circle cx="24" cy="24" r="15" opacity="0.35"/><circle cx="24" cy="24" r="21" opacity="0.18"/></svg>
                        {else}
                            <svg width="36" height="36" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" class="text-parch-primary" aria-hidden="true"><circle cx="24" cy="10" r="3"/><circle cx="10" cy="32" r="3"/><circle cx="38" cy="32" r="3"/><circle cx="17" cy="38" r="3"/><circle cx="31" cy="38" r="3"/><path d="M24 13l-12 17M24 13l12 17M12 33l5 4M36 33l-5 4M14 32h22"/></svg>
                        {/if}
                    </div>

                    <div class="font-mono text-[10px] uppercase tracking-widest2 text-parch-tertiary mb-2 tabular-nums">Step {$s['n']}</div>
                    <h3 class="font-display text-[19px] tracking-tighter text-parch-primary mb-3 leading-tight">{$s['title']}</h3>
                    <p class="text-parch-secondary text-[13.5px] leading-[1.65]">{$s['body']}</p>

                    {* Connector arrow on desktop, between steps *}
                    {if $i < 3}
                        <span class="hidden lg:flex absolute right-[-12px] top-12 w-6 h-6 items-center justify-center bg-cream-base text-parch-dim z-10" aria-hidden="true">
                            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M1 5h12m0 0L9 1m4 4L9 9"/></svg>
                        </span>
                    {/if}
                </article>
            {/foreach}
        </div>

    </div>
</section>

{* ============================================ 03 · TOP ANTIBODIES ===== *}
{*
 * Top antibodies by cache-hit count, passed by HomeController::index() via
 * EntryService::findTopByCacheHits(10). Each row is a stdClass with the
 * pre-joined stats columns (cache_hits, value_protected_usd, last_block_at).
 *}

<section class="relative bg-ink-base">
    <div class="max-w-[1400px] mx-auto px-7 pt-20 pb-16">

        <div class="flex flex-wrap items-end justify-between gap-6 mb-8">
            <div>
                <div class="flex items-center gap-3 mb-3">
                    <span class="font-mono text-[10.5px] text-fg-tertiary tabular-nums">03</span>
                    <span class="font-mono text-[10.5px] text-fg-dim">·</span>
                    <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Top antibodies</span>
                    <span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
                    <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-dim">by cache hits</span>
                </div>
                <h2 class="font-display text-[34px] font-light tracking-tighter text-fg-primary leading-[1.05]">
                    What the network is blocking the most.
                </h2>
                <p class="text-fg-secondary text-[14px] leading-[1.6] mt-3 max-w-[520px]">
                    Each row is a published antibody, ranked by how often its matcher has caught a check. Click any IMM ID to inspect.
                </p>
            </div>
            <a href="/dashboard" class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary hover:text-fg-primary transition-colors inline-flex items-center gap-1.5 self-start">
                Open dashboard
                <svg width="11" height="11" viewBox="0 0 12 12" aria-hidden="true"><path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>
            </a>
        </div>

        <div class="border-t border-ink-line/60">
            {if count($topAntibodies ?? []) === 0}
                <div class="py-8 text-center font-mono text-[11.5px] text-fg-dim">
                    No antibodies published yet. The first one will appear here.
                </div>
            {/if}
            {foreach $topAntibodies ?? [] as $i => $ab}
                {var $verdictDot = $ab->verdict === 'malicious' ? 'bg-threat-500' : 'bg-caution-500'}
                {var $typeUpper = strtoupper($ab->type)}
                {var $reasoning = trim((string) ($ab->redacted_reasoning ?? '')) !== ''
                    ? trim((string) $ab->redacted_reasoning)
                    : 'no reasoning recorded'}
                {var $reasoningTrunc = mb_strlen($reasoning) > 80 ? mb_substr($reasoning, 0, 78) . '…' : $reasoning}
                {var $publisherDisplay = $ab->publisher_ens
                    ?? ('0x' . substr($ab->publisher_hex, 0, 6) . '…' . substr($ab->publisher_hex, -4))}
                {var $isLast = $i === count($topAntibodies) - 1}
                <a href="/antibody/{$ab->imm_id}" data-event="{$ab->verdict}"
                   class="grid grid-cols-[14px_72px_148px_120px_1fr_180px] gap-4 items-center py-3.5 {$isLast ? '' : 'border-b border-ink-line/40'} hover:bg-ink-elevated/40 transition-colors group">
                    <span class="inline-flex h-1.5 w-1.5 rounded-full {$verdictDot}" aria-label="{$ab->verdict}"></span>
                    <span class="font-mono text-[11px] text-immune-500 tabular-nums text-right pr-2">{format('decimal', $ab->cache_hits, 0)}<span class="text-fg-dim ml-1">hits</span></span>
                    <span class="font-mono text-[12px] text-fg-primary group-hover:text-accent transition-colors">{$ab->imm_id}</span>
                    <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-secondary">{$typeUpper}</span>
                    <span class="text-fg-secondary text-[13.5px] truncate" title="{$reasoning}">{$reasoningTrunc}</span>
                    <span class="font-mono text-[11px] text-fg-tertiary text-right truncate">by {$publisherDisplay}</span>
                </a>
            {/foreach}
        </div>

    </div>
</section>

{* ============================================ 04 · ARCHITECTURE ===== *}
<section class="relative bg-ink-elevated/30 border-y border-ink-line/60">
    <div class="relative max-w-[1400px] mx-auto px-7 py-24">

        <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[10.5px] text-fg-tertiary tabular-nums">04</span>
            <span class="font-mono text-[10.5px] text-fg-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Architecture</span>
        </div>
        <h2 class="font-display text-[34px] font-light tracking-tighter text-fg-primary leading-[1.05] mb-12 max-w-[720px]">
            Three layers, one protocol.
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-[1080px]">
            <div>
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Speed layer</div>
                <h3 class="font-display text-[20px] tracking-tighter text-fg-primary mb-2">Gossip in seconds</h3>
                <p class="text-fg-secondary text-[14px] leading-[1.65]">Antibodies fan out across the AXL mesh through signed pub/sub topics. Every agent's local cache updates in well under one second.</p>
            </div>
            <div>
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Trust layer</div>
                <h3 class="font-display text-[20px] tracking-tighter text-fg-primary mb-2">Staked on chain</h3>
                <p class="text-fg-secondary text-[14px] leading-[1.65]">Each publisher locks 1 USDC for 72 hours. Match rewards split 70 / 20 / 10. False positives are challengeable. Skin in the game by design.</p>
            </div>
            <div>
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Verification layer</div>
                <h3 class="font-display text-[20px] tracking-tighter text-fg-primary mb-2">Sealed evidence</h3>
                <p class="text-fg-secondary text-[14px] leading-[1.65]">Detection runs in a 0G Compute TEE. Verdicts carry attestation hashes. The original context is encrypted to the enclave key and never shown.</p>
            </div>
        </div>
    </div>
</section>

{* ============================================ 05 · FOR DEVELOPERS ===== *}
<section class="relative bg-ink-base">
    <div class="absolute inset-0 dot-bg opacity-50 pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 py-24">

        <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[10.5px] text-fg-tertiary tabular-nums">05</span>
            <span class="font-mono text-[10.5px] text-fg-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">For developers</span>
        </div>
        <h2 class="font-display text-[40px] font-light tracking-tighter text-fg-primary leading-[1.05] mb-4 max-w-[720px]">
            One call before any agent action.
        </h2>
        <p class="text-fg-secondary text-[15.5px] leading-[1.65] max-w-[640px] mb-14">
            The SDK is a single import. Pass any tx or context to <code class="font-mono text-[14px] text-fg-primary">immunity.check()</code> and the network responds with a verdict, evidence, and matching antibodies before you sign.
        </p>

        <div class="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-10 items-start">

            {* Code sample with window chrome *}
            <div class="border border-ink-line/60 rounded-sm bg-ink-elevated/40 overflow-hidden shadow-panel">
                <header class="flex items-center justify-between gap-3 px-4 py-2.5 border-b border-ink-line/60 bg-ink-sunken/60">
                    <div class="flex items-center gap-2">
                        <span class="inline-flex h-2.5 w-2.5 rounded-full bg-threat-500/70" aria-hidden="true"></span>
                        <span class="inline-flex h-2.5 w-2.5 rounded-full bg-caution-500/70" aria-hidden="true"></span>
                        <span class="inline-flex h-2.5 w-2.5 rounded-full bg-immune-500/70" aria-hidden="true"></span>
                    </div>
                    <span class="font-mono text-[11px] text-fg-tertiary">agent.ts</span>
                    <button data-copy-btn="#sdk-code" class="font-mono text-[10px] uppercase tracking-widest2 text-fg-tertiary hover:text-accent transition-colors inline-flex items-center gap-1.5"
                            aria-label="Copy code">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                        <span data-copy-label>Copy</span>
                    </button>
                </header>
                {syntax off}
                <pre id="sdk-code" class="font-mono text-[12.5px] leading-[1.7] px-5 py-5 overflow-x-auto m-0"><code><span class="text-threat-300">import</span> <span class="text-fg-primary">{ Immunity }</span> <span class="text-threat-300">from</span> <span class="text-immune-300">"@immunity-protocol/sdk"</span><span class="text-fg-tertiary">;</span>

<span class="text-threat-300">const</span> immunity <span class="text-fg-tertiary">=</span> <span class="text-threat-300">new</span> <span class="text-accent-soft">Immunity</span><span class="text-fg-tertiary">({</span>
  wallet<span class="text-fg-tertiary">,</span>

  <span class="text-fg-dim italic">// Called when verdict is SUSPICIOUS. Return true to allow, false to block.</span>
  <span class="text-fg-dim italic">// Defaults to "deny" if not provided.</span>
  onEscalate<span class="text-fg-tertiary">:</span> <span class="text-threat-300">async</span> <span class="text-fg-tertiary">(</span>verdict<span class="text-fg-tertiary">)</span> <span class="text-fg-tertiary">=&gt;</span> <span class="text-fg-tertiary">{</span>
    <span class="text-threat-300">return</span> <span class="text-threat-300">await</span> <span class="text-accent-soft">notifyOperator</span><span class="text-fg-tertiary">({</span>
      antibody<span class="text-fg-tertiary">:</span> verdict<span class="text-fg-tertiary">.</span>antibodies<span class="text-fg-tertiary">[</span><span class="text-accent-soft">0</span><span class="text-fg-tertiary">],</span>
      confidence<span class="text-fg-tertiary">:</span> verdict<span class="text-fg-tertiary">.</span>confidence<span class="text-fg-tertiary">,</span>
      explanation<span class="text-fg-tertiary">:</span> verdict<span class="text-fg-tertiary">.</span>explanation<span class="text-fg-tertiary">,</span>
    <span class="text-fg-tertiary">});</span>
  <span class="text-fg-tertiary">},</span>

  escalationTimeout<span class="text-fg-tertiary">:</span> <span class="text-accent-soft">300</span><span class="text-fg-tertiary">,</span> <span class="text-fg-dim italic">// seconds, default 300</span>
  onTimeout<span class="text-fg-tertiary">:</span> <span class="text-immune-300">"deny"</span><span class="text-fg-tertiary">,</span> <span class="text-fg-dim italic">// "deny" | "allow", default "deny"</span>
<span class="text-fg-tertiary">});</span>

<span class="text-fg-dim italic">// Before any agent action</span>
<span class="text-threat-300">const</span> result <span class="text-fg-tertiary">=</span> <span class="text-threat-300">await</span> immunity<span class="text-fg-tertiary">.</span><span class="text-accent-soft">check</span><span class="text-fg-tertiary">(</span>tx<span class="text-fg-tertiary">,</span> context<span class="text-fg-tertiary">);</span>

<span class="text-threat-300">if</span> <span class="text-fg-tertiary">(!</span>result<span class="text-fg-tertiary">.</span>allowed<span class="text-fg-tertiary">)</span> <span class="text-fg-tertiary">{</span>
  console<span class="text-fg-tertiary">.</span><span class="text-accent-soft">warn</span><span class="text-fg-tertiary">(</span><span class="text-immune-300">`Blocked by ${result.antibodies[0].immId}: ${result.reason}`</span><span class="text-fg-tertiary">);</span>
  <span class="text-threat-300">return</span><span class="text-fg-tertiary">;</span>
<span class="text-fg-tertiary">}</span>

<span class="text-fg-dim italic">// Safe to proceed</span>
<span class="text-threat-300">await</span> wallet<span class="text-fg-tertiary">.</span><span class="text-accent-soft">sendTransaction</span><span class="text-fg-tertiary">(</span>tx<span class="text-fg-tertiary">);</span></code></pre>
                {/syntax}
            </div>

            {* Bullets + CTA *}
            <div>
                <div class="font-mono text-[10px] uppercase tracking-widest2 text-fg-tertiary mb-5">What you get</div>
                <ul class="space-y-3.5 text-[14px] text-fg-secondary leading-[1.6]">
                    <li class="flex items-start gap-3">
                        <span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-500 shrink-0" aria-hidden="true"></span>
                        Sub-millisecond local cache via <a href="https://github.com/ophelios-studio/axl-pubsub" rel="noopener" class="font-mono text-[12.5px] text-fg-primary hover:text-accent transition-colors underline-offset-4 hover:underline">axl-pubsub</a>
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-500 shrink-0" aria-hidden="true"></span>
                        Automatic on-chain settlement on every check
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-500 shrink-0" aria-hidden="true"></span>
                        TEE-backed semantic detection for novel threats
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-500 shrink-0" aria-hidden="true"></span>
                        Configurable escalation handlers for SUSPICIOUS verdicts
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-500 shrink-0" aria-hidden="true"></span>
                        Cross-chain antibody mirroring out of the box
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-500 shrink-0" aria-hidden="true"></span>
                        Open source, MIT licensed
                    </li>
                </ul>
                <a href="https://docs.immunity.xyz/sdk" rel="noopener" class="group inline-flex items-center gap-2 mt-7 font-mono text-[11px] uppercase tracking-widest2 text-fg-primary hover:text-accent transition-colors border-b border-fg-tertiary/40 hover:border-accent pb-1">
                    Read the SDK reference
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="none" class="group-hover:translate-x-0.5 transition-transform" aria-hidden="true"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            </div>

        </div>
    </div>
</section>

{* ============================================ 06 · ANTIBODY TYPES ===== *}
{var $abTypes = [
  ['name' => 'ADDRESS',      'tone' => 'text-fg-secondary',
   'desc' => 'Blacklisted wallets and contracts',
   'example' => '0xBadDrainer... → blocked everywhere'],
  ['name' => 'CALL_PATTERN', 'tone' => 'text-caution-300',
   'desc' => 'Function selector + argument shape',
   'example' => 'approve(MAX_UINT256, 0xBad) → blocked'],
  ['name' => 'BYTECODE',     'tone' => 'text-immune-300',
   'desc' => 'Runtime bytecode hash for clones',
   'example' => '0x9c4f...8a2b → matches any deploy'],
  ['name' => 'GRAPH',        'tone' => 'text-accent-soft',
   'desc' => 'Multi-hop taint topology',
   'example' => 'funded via Tornado < 24h → suspicious'],
  ['name' => 'SEMANTIC',     'tone' => 'text-threat-300',
   'desc' => 'Manipulation patterns + injection',
   'example' => '"send 0.01, I&apos;ll send 0.02 back" → blocked'],
]}

<section class="relative bg-ink-base">
    <div class="absolute inset-0 grid-bg opacity-25 pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 py-24">

        <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[10.5px] text-fg-tertiary tabular-nums">06</span>
            <span class="font-mono text-[10.5px] text-fg-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Antibody types</span>
        </div>
        <h2 class="font-display text-[34px] font-light tracking-tighter text-fg-primary leading-[1.05] mb-4 max-w-[720px]">
            Five ways to recognize a threat.
        </h2>
        <p class="text-fg-secondary text-[14.5px] leading-[1.65] max-w-[640px] mb-12">
            Five types, one rule: match cheaply when you can, verify when you must. Most checks resolve against the local cache in under a millisecond. Novel threats round-trip to the TEE for a signed verdict.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-px bg-ink-line/60">
            {foreach $abTypes as $t}
                <a href="https://docs.immunity.xyz/antibody-types#{$t['name']|lower}" rel="noopener"
                   class="group block bg-ink-base hover:bg-ink-elevated/50 transition-colors p-6 min-h-[180px] flex flex-col">
                    <div class="font-mono text-[14px] tracking-widest2 {$t['tone']} mb-4">{$t['name']}</div>
                    <p class="text-fg-secondary text-[13px] leading-[1.5] mb-5">{$t['desc']}</p>
                    <code class="font-mono text-[10.5px] text-fg-tertiary leading-[1.55] mt-auto bg-ink-sunken/60 border border-ink-line/40 px-2.5 py-2 rounded-sm break-all">{$t['example']|noescape}</code>
                </a>
            {/foreach}
        </div>

    </div>
</section>

{* ============================================ TICKER · attack categories ===== *}
{var $threatLabels = [
  'DRAINER WALLETS', 'PROMPT INJECTION', 'HONEYPOT TOKENS', 'UNLIMITED APPROVALS',
  'SOCIAL ENGINEERING', 'TYPOSQUATTING', 'MIXER ROUTING', 'BYTECODE CLONES',
  'PHISHING SIGNATURES', 'SANDWICH BOTS', 'SYBIL FUNDING', 'ROUTING EXPLOITS',
  'ORACLE MANIPULATION', 'PERMIT2 ABUSE', 'SEED DRAINERS',
]}
<aside class="relative bg-ink-base border-y border-ink-line/60 overflow-hidden" aria-label="Attack categories defended">
    <div class="ticker-track-reverse py-5 select-none">
        {for $pass = 0; $pass < 2; $pass++}
            <ul class="flex items-center gap-12 px-6" aria-hidden="{$pass === 1 ? 'true' : 'false'}">
                {foreach $threatLabels as $label}
                    <li class="font-mono text-[13.5px] uppercase tracking-widest2 text-fg-secondary whitespace-nowrap inline-flex items-center gap-3">
                        <span class="inline-flex h-1 w-1 rounded-full bg-threat-500/70" aria-hidden="true"></span>
                        {$label}
                    </li>
                {/foreach}
            </ul>
        {/for}
    </div>
</aside>

{* ============================================ 07 · TWO-LAYER PROTECTION ===== *}
<section class="relative bg-cream-base text-parch-primary">
    <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, rgba(245,241,232,0) 0%, rgba(216,208,189,0.25) 100%);" aria-hidden="true"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 py-24">

        <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[10.5px] text-parch-tertiary tabular-nums">07</span>
            <span class="font-mono text-[10.5px] text-parch-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-parch-tertiary">Two-layer protection</span>
        </div>
        <h2 class="font-display text-[40px] font-light tracking-tighter leading-[1.05] mb-4 max-w-[720px]">
            Defends from both sides.
        </h2>
        <p class="text-parch-secondary text-[15.5px] leading-[1.65] max-w-[640px] mb-14">
            Agents check before they sign. Pools check before they swap. Same registry, two enforcement points, no install required for the second.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-cream-line mb-14">

            {* SDK side *}
            <div class="bg-cream-base p-8 hover:bg-cream-elevated transition-colors">
                <div class="flex items-start justify-between mb-6">
                    <div>
                        <div class="font-mono text-[10px] uppercase tracking-widest2 text-parch-tertiary mb-2">For agent operators</div>
                        <h3 class="font-display text-[24px] tracking-tighter text-parch-primary leading-tight">SDK protection</h3>
                    </div>
                    <svg width="44" height="44" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" class="text-parch-primary shrink-0" aria-hidden="true">
                        <circle cx="20" cy="24" r="11"/>
                        <circle cx="20" cy="24" r="3" fill="currentColor"/>
                        <path d="M34 12l8 4v8c0 6-4 10-8 12-4-2-8-6-8-12v-8l8-4z" fill="rgba(196,90,90,0.10)"/>
                    </svg>
                </div>
                <p class="text-parch-secondary text-[14px] leading-[1.65] mb-5">
                    Install the SDK in your agent. Every action is checked against the network's collective immunity before signing. Works on any chain, any pool, any tx type.
                </p>
                <ul class="space-y-2.5 text-[13px] text-parch-secondary leading-[1.55]">
                    <li class="flex items-start gap-3"><span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-700 shrink-0" aria-hidden="true"></span>Drop-in npm install</li>
                    <li class="flex items-start gap-3"><span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-700 shrink-0" aria-hidden="true"></span>Local cache, sub-ms checks</li>
                    <li class="flex items-start gap-3"><span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-700 shrink-0" aria-hidden="true"></span>Per-operator config</li>
                </ul>
            </div>

            {* Hook side *}
            <div class="bg-cream-base p-8 hover:bg-cream-elevated transition-colors">
                <div class="flex items-start justify-between mb-6">
                    <div>
                        <div class="font-mono text-[10px] uppercase tracking-widest2 text-parch-tertiary mb-2">For pool deployers</div>
                        <h3 class="font-display text-[24px] tracking-tighter text-parch-primary leading-tight">Hook protection</h3>
                    </div>
                    <svg width="44" height="44" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" class="text-parch-primary shrink-0" aria-hidden="true">
                        <path d="M8 26c4-8 12-8 16 0s12 8 16 0" fill="rgba(122,184,122,0.10)"/>
                        <path d="M8 32c4-8 12-8 16 0s12 8 16 0"/>
                        <path d="M34 8l8 4v8c0 6-4 10-8 12-4-2-8-6-8-12v-8l8-4z" fill="rgba(196,90,90,0.10)"/>
                    </svg>
                </div>
                <p class="text-parch-secondary text-[14px] leading-[1.65] mb-5">
                    Deploy a Uniswap v4 pool with the Immunity hook. Every swap on your pool is checked against the global registry. LPs are protected automatically — no install required.
                </p>
                <ul class="space-y-2.5 text-[13px] text-parch-secondary leading-[1.55]">
                    <li class="flex items-start gap-3"><span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-700 shrink-0" aria-hidden="true"></span>v4 BeforeSwap hook</li>
                    <li class="flex items-start gap-3"><span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-700 shrink-0" aria-hidden="true"></span>Mirrored ADDRESS antibodies per chain</li>
                    <li class="flex items-start gap-3"><span class="inline-flex mt-2 h-1 w-1 rounded-full bg-immune-700 shrink-0" aria-hidden="true"></span>Blocks bad actors AND bad assets</li>
                </ul>
            </div>
        </div>

        {* Coverage matrix *}
        {var $matrix = [
          ['scenario' => 'Agent uses SDK,    pool has hook', 'sdk' => true,  'hook' => true,  'note' => 'Both layers active. Maximum coverage.'],
          ['scenario' => 'Agent uses SDK,    pool has none', 'sdk' => true,  'hook' => false, 'note' => 'Agent-side only. Per-agent.'],
          ['scenario' => 'Agent has none,    pool has hook', 'sdk' => false, 'hook' => true,  'note' => 'Pool-side only. Protects every LP.'],
          ['scenario' => 'Agent has none,    pool has none', 'sdk' => false, 'hook' => false, 'note' => 'No defense. Use the public feed.'],
        ]}
        <div class="border border-cream-line rounded-sm bg-cream-elevated overflow-hidden">
            <header class="px-5 py-3 border-b border-cream-line flex items-center justify-between bg-cream-sunken">
                <span class="font-mono text-[10px] uppercase tracking-widest2 text-parch-tertiary">Coverage matrix</span>
                <span class="font-mono text-[10px] text-parch-dim">tx-by-tx outcomes</span>
            </header>
            <table class="w-full">
                <thead>
                    <tr class="border-b border-cream-line/70 bg-cream-sunken/40">
                        <th class="font-mono text-[9.5px] uppercase tracking-widest2 text-parch-tertiary font-normal text-left px-5 py-3">Scenario</th>
                        <th class="font-mono text-[9.5px] uppercase tracking-widest2 text-parch-tertiary font-normal text-center px-3 py-3">SDK</th>
                        <th class="font-mono text-[9.5px] uppercase tracking-widest2 text-parch-tertiary font-normal text-center px-3 py-3">Hook</th>
                        <th class="font-mono text-[9.5px] uppercase tracking-widest2 text-parch-tertiary font-normal text-left px-5 py-3">Outcome</th>
                    </tr>
                </thead>
                <tbody>
                {foreach $matrix as $i => $r}
                    <tr class="border-b border-cream-line/50 last:border-0 hover:bg-cream-elevated/60 transition-colors">
                        <td class="px-5 py-3 text-[13px] text-parch-primary">{$r['scenario']}</td>
                        <td class="px-3 py-3 text-center">
                            {if $r['sdk']}
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-immune-700 inline-block" aria-label="yes"><polyline points="20 6 9 17 4 12"/></svg>
                            {else}
                                <span class="text-parch-dim font-mono text-[14px]">—</span>
                            {/if}
                        </td>
                        <td class="px-3 py-3 text-center">
                            {if $r['hook']}
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-immune-700 inline-block" aria-label="yes"><polyline points="20 6 9 17 4 12"/></svg>
                            {else}
                                <span class="text-parch-dim font-mono text-[14px]">—</span>
                            {/if}
                        </td>
                        <td class="px-5 py-3 text-[12.5px] text-parch-secondary">{$r['note']}</td>
                    </tr>
                {/foreach}
                </tbody>
            </table>
        </div>

    </div>
</section>

{* ============================================ 08 · BUILT ON ===== *}
{var $sponsors = [
  ['name' => 'Gensyn AXL',   'role' => 'Speed layer',
   'desc' => 'Peer-to-peer antibody gossip via custom pub/sub.'],
  ['name' => '0G Chain',     'role' => 'Trust layer',
   'desc' => 'On-chain antibody registry, stake, and settlement.'],
  ['name' => '0G Storage',   'role' => 'Verification layer',
   'desc' => 'Sealed evidence bundles and public envelopes.'],
  ['name' => '0G Compute',   'role' => 'Detection layer',
   'desc' => 'Verifiable TEE inference for semantic threats.'],
  ['name' => 'Uniswap v4',   'role' => 'Protection layer',
   'desc' => 'Pool-level hooks for collective LP defense.'],
]}

<section class="relative bg-ink-base">
    <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, rgba(14,14,13,1) 0%, rgba(28,28,26,0.6) 100%);" aria-hidden="true"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 py-24">

        <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[10.5px] text-fg-tertiary tabular-nums">08</span>
            <span class="font-mono text-[10.5px] text-fg-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Built on</span>
        </div>
        <h2 class="font-display text-[34px] font-light tracking-tighter text-fg-primary leading-[1.05] mb-4 max-w-[720px]">
            What runs underneath.
        </h2>
        <p class="text-fg-secondary text-[14.5px] leading-[1.65] max-w-[640px] mb-12">
            Each sponsor handles one job. Together they make the protocol fast, trustworthy, and verifiable end-to-end.
        </p>

        <div class="border-t border-ink-line/50">
            {foreach $sponsors as $s}
                <div class="grid grid-cols-[64px_1fr_1.6fr] md:grid-cols-[120px_1fr_1.6fr] items-center gap-6 py-6 border-b border-ink-line/40 hover:bg-ink-elevated/30 transition-colors">
                    {* Placeholder mark *}
                    <div class="flex items-center justify-center h-12 w-12 md:h-14 md:w-14 border border-ink-line/60 rounded-sm bg-ink-elevated/40 font-mono text-[10px] tracking-widest2 text-fg-dim uppercase select-none">
                        {$s['name']|substr(0, 2)}
                    </div>
                    <div>
                        <div class="font-display text-[18px] tracking-tighter text-fg-primary leading-tight">{$s['name']}</div>
                        <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-accent-soft mt-1">{$s['role']}</div>
                    </div>
                    <p class="text-fg-secondary text-[13.5px] leading-[1.65]">{$s['desc']}</p>
                </div>
            {/foreach}
        </div>

        <p class="font-mono text-[10px] uppercase tracking-widest2 text-fg-dim mt-6">
            Sponsor logos pending. Placeholder marks shown above.
        </p>

    </div>
</section>

{* ============================================ 09 · PUBLIC FEED ===== *}
<section class="relative bg-ink-elevated/30 border-t border-accent/30">
    <div class="absolute inset-0 dot-bg opacity-40 pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-[820px] mx-auto px-7 py-24 text-center">

        <div class="flex items-center justify-center gap-3 mb-3">
            <span class="font-mono text-[10.5px] text-fg-tertiary tabular-nums">09</span>
            <span class="font-mono text-[10.5px] text-fg-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Public feed</span>
        </div>
        <h2 class="font-display text-[34px] font-light tracking-tighter text-fg-primary leading-[1.1] mb-5">
            A public threat feed for AI agents.
        </h2>
        <p class="text-fg-secondary text-[15px] leading-[1.7] mb-9 max-w-[640px] mx-auto">
            Every antibody is a public artifact. Subscribe via RSS, JSON, or webhook. Wallet UIs, security researchers, and other agents can consume the feed without running an SDK.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-3">
            <a href="/feed/antibodies.rss" class="group inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-ink-line/80 bg-ink-base/50 text-fg-secondary hover:text-accent hover:border-accent/40 transition-colors">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1.5" fill="currentColor"/></svg>
                <span class="font-mono text-[11px] uppercase tracking-widest2">RSS feed</span>
            </a>
            <a href="/feed/antibodies.json" class="group inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-ink-line/80 bg-ink-base/50 text-fg-secondary hover:text-accent hover:border-accent/40 transition-colors">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M8 4H6a2 2 0 0 0-2 2v4c0 1.1-.9 2-2 2 1.1 0 2 .9 2 2v4a2 2 0 0 0 2 2h2M16 4h2a2 2 0 0 1 2 2v4c0 1.1.9 2 2 2-1.1 0-2 .9-2 2v4a2 2 0 0 1-2 2h-2"/></svg>
                <span class="font-mono text-[11px] uppercase tracking-widest2">JSON feed</span>
            </a>
            <a href="https://docs.immunity.xyz/feeds/webhooks" rel="noopener" class="group inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-ink-line/80 bg-ink-base/50 text-fg-secondary hover:text-accent hover:border-accent/40 transition-colors">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="18" cy="5" r="2.5"/><circle cx="6" cy="12" r="2.5"/><circle cx="18" cy="19" r="2.5"/><path d="M8.5 13l7 4M15.5 6.5l-7 4"/></svg>
                <span class="font-mono text-[11px] uppercase tracking-widest2">Webhook docs</span>
            </a>
        </div>

    </div>
</section>

<script src="{asset('/javascripts/live.js')}"></script>
<script>
(function () {
  const STATS_URL = '/api/v1/network/stats';
  const HEARTBEAT_URL = '/api/v1/network/heartbeat-status';

  function fmtNumber(v) {
    if (v === null || v === undefined || v === '') return '-';
    const n = Number(v);
    if (!Number.isFinite(n)) return '-';
    return n.toLocaleString('en-US', { maximumFractionDigits: 0 });
  }
  function fmtMoney(v) {
    if (v === null || v === undefined || v === '') return '-';
    const n = Number(v);
    if (!Number.isFinite(n)) return '-';
    return '$' + n.toLocaleString('en-US', { maximumFractionDigits: 0 });
  }
  function fmtDelta(v, money) {
    if (v === null || v === undefined || v === '') return '';
    const n = Number(v);
    if (!Number.isFinite(n)) return '';
    const sign = n >= 0 ? '+' : '-';
    const abs = Math.abs(n);
    return sign + (money ? '$' : '') + abs.toLocaleString('en-US', { maximumFractionDigits: 0 }) + ' in 1h';
  }
  // 0G Compute pricing for qwen-2.5-7b-instruct: 50 gwei in / 100 gwei out,
  // ~2k tokens per inference, 0G assumed at ~$0.50 spot. Yields ~$0.0001 per
  // call. Update if 0G pricing or token value moves materially.
  const COST_PER_CALL_USD = 0.0001;
  function fmtComputeSaved(callsSaved) {
    if (callsSaved === null || callsSaved === undefined || callsSaved === '') return '≈ $0';
    const n = Number(callsSaved);
    if (!Number.isFinite(n) || n <= 0) return '≈ $0';
    const usd = n * COST_PER_CALL_USD;
    if (usd < 0.01) return '≈ <$0.01';
    if (usd < 1)    return '≈ $' + usd.toFixed(2);
    return '≈ $' + usd.toLocaleString('en-US', { maximumFractionDigits: 0 });
  }

  // Skip the DOM write when the formatted value hasn't changed; reassigning
  // the same string still triggers a brief repaint that reads as a flicker.
  function setText(el, next) { if (el.textContent !== next) el.textContent = next; }

  Live.poll(STATS_URL, 4000, function (data) {
    const tiles = data.tiles || {};
    document.querySelectorAll('[data-stat]').forEach(function (el) {
      const m = el.getAttribute('data-stat');
      if (tiles[m]) setText(el, fmtNumber(tiles[m].value));
    });
    document.querySelectorAll('[data-stat-money]').forEach(function (el) {
      const m = el.getAttribute('data-stat-money');
      if (tiles[m]) setText(el, fmtMoney(tiles[m].value));
    });
    document.querySelectorAll('[data-delta]').forEach(function (el) {
      const m = el.getAttribute('data-delta');
      if (tiles[m]) setText(el, fmtDelta(tiles[m].delta_1h, false));
    });
    document.querySelectorAll('[data-delta-money]').forEach(function (el) {
      const m = el.getAttribute('data-delta-money');
      if (tiles[m]) setText(el, fmtDelta(tiles[m].delta_1h, true));
    });
    document.querySelectorAll('[data-compute-saved]').forEach(function (el) {
      const m = el.getAttribute('data-compute-saved');
      if (tiles[m]) setText(el, fmtComputeSaved(tiles[m].value));
    });
  });

  Live.poll(HEARTBEAT_URL, 4000, function (data) {
    const pulse = document.getElementById('live-pulse');
    const label = document.getElementById('live-label');
    if (!pulse || !label) return;
    const age = data.age_seconds;
    let color, text;
    // Cron fires every 60s, so anything under ~90s is healthy (green).
    // Amber kicks in only when we have actually fallen behind one tick.
    if (age === null || age === undefined) { color = 'bg-fg-tertiary'; text = 'OFFLINE'; }
    else if (age < 90) { color = 'bg-immune-500'; text = 'LIVE'; }
    else if (age < 240) { color = 'bg-amber-500'; text = 'STALE'; }
    else { color = 'bg-red-500'; text = 'OFFLINE'; }
    pulse.className = 'inline-flex h-1.5 w-1.5 rounded-full pulse-soft ' + color;
    label.textContent = text;
  });
})();
</script>

{/block}
