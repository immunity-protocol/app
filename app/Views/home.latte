                <span class="font-mono text-[12px] text-fg-primary group-hover:text-accent transition-colors">IMM-2026-0263</span>
                <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">expired</span>
                <span class="text-fg-secondary text-[13.5px] truncate">72h stake released, 0 challenges, +0.41 USDC to publisher</span>
                <span class="font-mono text-[11px] text-fg-tertiary text-right truncate">by sentinel.eth</span>
            </a>

        </div>

        {* Legend *}
        <div class="flex items-center justify-end gap-5 mt-6 font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">
            <span class="inline-flex items-center gap-2"><span class="inline-flex h-1.5 w-1.5 rounded-full bg-accent"></span>mint</span>
            <span class="inline-flex items-center gap-2"><span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500"></span>block</span>
