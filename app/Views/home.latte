                <span class="inline-flex h-1.5 w-1.5 rounded-full bg-accent" aria-label="mint"></span>
                <span class="font-mono text-[11px] text-fg-tertiary tabular-nums">6m ago</span>
                <span class="font-mono text-[12px] text-fg-primary group-hover:text-accent transition-colors">IMM-2026-0289</span>
                <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">minted</span>
                <span class="text-fg-secondary text-[13.5px] truncate">CALL_PATTERN, approve(MAX_UINT256, 0xbad..1234)</span>
                <span class="font-mono text-[11px] text-fg-tertiary text-right truncate">by sentinel.eth</span>
            </a>

            {* ======== row 7: block ======== *}
            <a href="/antibody/IMM-2026-0271" class="grid grid-cols-[14px_64px_148px_118px_1fr_200px] gap-4 items-center py-3.5 border-b border-ink-line/40 hover:bg-ink-elevated/40 transition-colors group">
                <span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500" aria-label="block"></span>
                <span class="font-mono text-[11px] text-fg-tertiary tabular-nums">9m ago</span>
                <span class="font-mono text-[12px] text-fg-primary group-hover:text-accent transition-colors">IMM-2026-0271</span>
                <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">blocked</span>
                <span class="text-fg-secondary text-[13.5px] truncate">$890 protected, swap intercepted before signature</span>
                <span class="font-mono text-[11px] text-fg-tertiary text-right truncate">tx 0x42c9..d4f7</span>
            </a>

            {* ======== row 8: expire ======== *}
            <a href="/antibody/IMM-2026-0263" class="grid grid-cols-[14px_64px_148px_118px_1fr_200px] gap-4 items-center py-3.5 hover:bg-ink-elevated/40 transition-colors group">
