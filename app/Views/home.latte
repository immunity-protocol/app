                <span class="font-mono text-[11px] text-fg-tertiary text-right truncate">by huntress.eth</span>
            </a>

            {* ======== row 2: block ======== *}
            <a href="/antibody/IMM-2026-0287" class="grid grid-cols-[14px_64px_148px_118px_1fr_200px] gap-4 items-center py-3.5 border-b border-ink-line/40 hover:bg-ink-elevated/40 transition-colors group">
                <span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500" aria-label="block"></span>
