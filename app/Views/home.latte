{layout layouts/main.latte}

{block title}Immunity, decentralized threat intelligence for AI agents{/block}

{block head}
<script>
window.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('[data-copy-btn]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-copy-btn');
      const text = btn.getAttribute('data-copy-value') || (document.querySelector(target)?.innerText ?? '');
      navigator.clipboard?.writeText(text);
      const label = btn.querySelector('[data-copy-label]');
      if (label) {
        const prev = label.innerText;
        label.innerText = 'Copied';
        btn.classList.add('copy-flash');
        setTimeout(() => { label.innerText = prev; btn.classList.remove('copy-flash'); }, 1400);
      }
    });
  });
});
</script>
{/block}

{block content}

{* ============================================================ HERO ===== *}
<section class="relative overflow-hidden bg-ink-base">

    {* Ambient background: warm radial glow, dot pattern, large faded mark *}
    <div class="absolute inset-0 hero-glow pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 dot-bg opacity-50 pointer-events-none" aria-hidden="true"></div>

    {* Large faded watermark on the right *}
    <div class="absolute -right-24 top-1/2 -translate-y-1/2 w-[640px] h-[640px] opacity-[0.035] pointer-events-none hidden lg:block"
         style="background: var(--fg-primary); -webkit-mask: url(/assets/images/immunity-mark.png) center/contain no-repeat; mask: url(/assets/images/immunity-mark.png) center/contain no-repeat;"
         aria-hidden="true"></div>

    {* Bottom gradient for text legibility on long pages *}
    <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-b from-transparent to-ink-base pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 pt-24 pb-28 min-h-[80vh] flex flex-col justify-center">

        {* Kicker, italic, almost a whisper *}
        <p class="font-display italic text-fg-tertiary text-[15px] mb-5 tracking-tight">
            A vaccine for AI agents.
        </p>

        {* Headline, large, restrained *}
        <h1 class="font-display display-xl font-light tracking-tightest text-fg-primary text-[56px] sm:text-[76px] md:text-[96px] leading-[0.95] mb-9 max-w-[1100px]">
            Decentralized threat<br>intelligence that
            <span class="italic font-light text-accent">propagates in seconds</span>.
        </h1>

        {* Lede *}
        <p class="text-fg-secondary text-[18px] leading-[1.6] max-w-[640px] mb-10">
            When one agent encounters a malicious actor, every other agent learns within seconds. Antibodies are signed by their publisher, staked on chain, and globally addressable by a stable CVE-style identifier.
        </p>

        {* Install command block, the centerpiece *}
        <div class="max-w-[640px] mb-7">
            <div class="group relative flex items-stretch border border-ink-line/80 rounded-sm bg-ink-elevated/60 backdrop-blur-sm hover:border-fg-tertiary transition-colors overflow-hidden">
                <span class="inline-flex items-center px-4 py-3.5 font-mono text-[12px] text-fg-dim border-r border-ink-line/60 select-none" aria-hidden="true">$</span>
                <code id="install-cmd" class="flex-1 px-4 py-3.5 font-mono text-[14.5px] text-fg-primary bg-transparent overflow-x-auto whitespace-nowrap">npm install @immunity/sdk</code>
                <button data-copy-btn="#install-cmd" data-copy-value="npm install @immunity/sdk"
                        class="inline-flex items-center gap-2 px-4 py-3.5 border-l border-ink-line/60 text-fg-tertiary hover:text-accent hover:bg-ink-elevated transition-colors font-mono text-[10.5px] uppercase tracking-widest2"
                        aria-label="Copy install command">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                    <span data-copy-label>Copy</span>
                </button>
            </div>
            <p class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-dim mt-2.5">
                Drop-in. No config. Works on any chain.
            </p>
        </div>

        {* CTAs *}
        <div class="flex flex-wrap items-center gap-3">
            <a href="https://docs.immunity.xyz" rel="noopener" class="group inline-flex items-center gap-2 px-5 py-3 text-[13px] tracking-wide bg-fg-primary text-ink-base hover:bg-accent transition-colors rounded-sm">
                Read the protocol
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="opacity-60 group-hover:translate-x-0.5 transition-transform" aria-hidden="true"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/dashboard" class="group inline-flex items-center gap-2 px-5 py-3 text-[13px] tracking-wide border border-ink-line text-fg-secondary hover:text-fg-primary hover:border-fg-tertiary transition-colors rounded-sm">
                View live dashboard
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="opacity-50 group-hover:translate-x-0.5 transition-transform" aria-hidden="true"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
        </div>

    </div>
</section>

{* ============================================ 01 · NETWORK STATUS ===== *}
<section class="relative bg-ink-elevated/40 border-y border-ink-line/60">
    <div class="absolute inset-0 grid-bg opacity-20 pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 py-12">

        <div class="flex items-center gap-3 mb-7">
            <span class="font-mono text-[10.5px] text-fg-tertiary tabular-nums">01</span>
            <span class="font-mono text-[10.5px] text-fg-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Network status</span>
            <span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-immune-500">Live</span>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-y-10 md:gap-0">

            <div class="md:px-7 md:first:pl-0 md:border-r md:border-ink-line/60 md:last:border-r-0 md:last:pr-0">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3 flex items-center gap-2">
                    <span>Antibodies active</span>
                    <span class="inline-flex h-1 w-1 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
                </div>
                <div class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">312</div>
                <div class="font-mono text-[11px] text-immune-500 mt-3 inline-flex items-center gap-1.5">
                    <svg width="9" height="9" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 8l4-4 4 4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    +14 in 1h
                </div>
            </div>

            <div class="md:px-7 md:border-r md:border-ink-line/60">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Agents online</div>
                <div class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">1,247</div>
                <div class="font-mono text-[11px] text-immune-500 mt-3 inline-flex items-center gap-1.5">
                    <svg width="9" height="9" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 8l4-4 4 4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    +8 in 1h
                </div>
            </div>

            <div class="md:px-7 md:border-r md:border-ink-line/60">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Cache hits / hr</div>
                <div class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">18,492</div>
                <div class="font-mono text-[11px] text-fg-tertiary mt-3">avg 5.1 / agent</div>
            </div>

            <div class="md:px-7 md:border-r md:border-ink-line/60">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">LLM calls saved</div>
                <div class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">4,217</div>
                <div class="font-mono text-[11px] text-fg-tertiary mt-3">
                    <span class="text-immune-500">≈ $8,920</span> in compute
                </div>
            </div>

            <div class="md:px-7 md:last:pr-0">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Value protected</div>
                <div class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">$248,300</div>
                <div class="font-mono text-[11px] text-immune-500 mt-3 inline-flex items-center gap-1.5">
                    <svg width="9" height="9" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 8l4-4 4 4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    +$4,200 in 1h
                </div>
            </div>

        </div>
    </div>
</section>

{* ============================================ 02 · HOW IT WORKS ===== *}
<section class="relative bg-cream-base text-parch-primary">
    <div class="absolute inset-0 dot-bg-light opacity-60 pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 py-24">

        <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[10.5px] text-parch-tertiary tabular-nums">02</span>
            <span class="font-mono text-[10.5px] text-parch-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-parch-tertiary">How it works</span>
        </div>
        <h2 class="font-display text-[40px] font-light tracking-tighter leading-[1.05] mb-4 max-w-[720px]">
            From threat to immunity in 30 seconds.
        </h2>
        <p class="text-parch-secondary text-[15.5px] leading-[1.65] max-w-[640px] mb-14">
            One protocol, four steps, and the network is more resilient than it was a minute ago. No human in the loop.
        </p>

        {var $steps = [
          ['n' => '01', 'title' => 'Agent encounters a threat',
           'body' => 'An AI agent receives a suspicious tx, scraped content, or counterparty message and calls check() before acting.',
           'icon' => 'cell-alert'],
          ['n' => '02', 'title' => 'Detection runs in a TEE',
           'body' => 'Encrypted context goes to a 0G Compute enclave running qwen-2.5-7b. Verdict comes back signed with attestation.',
           'icon' => 'enclave'],
          ['n' => '03', 'title' => 'Antibody is minted and propagated',
           'body' => 'The publisher locks 1 USDC for 72h. The antibody hits 0G Chain for settlement and gossips across the AXL mesh.',
           'icon' => 'radiate'],
          ['n' => '04', 'title' => 'Every other agent is now immune',
           'body' => 'Local caches update in under a second. The same attack is blocked everywhere — by SDK on agents, by hook on Uniswap pools.',
           'icon' => 'mesh'],
        ]}

        <div class="relative grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-cream-line">
            {foreach $steps as $i => $s}
                <article class="relative bg-cream-base hover:bg-cream-elevated transition-colors p-7 group">

                    {* Icon *}
                    <div class="mb-6">
                        {if $s['icon'] === 'cell-alert'}
                            <svg width="36" height="36" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" class="text-parch-primary" aria-hidden="true"><circle cx="20" cy="24" r="11"/><circle cx="20" cy="24" r="3" fill="currentColor"/><path d="M36 12v10M36 28v0.5" stroke-linecap="round" stroke-width="2"/></svg>
                        {elseif $s['icon'] === 'enclave'}
                            <svg width="36" height="36" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" class="text-parch-primary" aria-hidden="true"><rect x="8" y="20" width="32" height="20" rx="2"/><path d="M14 20v-6a10 10 0 0 1 20 0v6"/><circle cx="24" cy="30" r="2.5"/></svg>
                        {elseif $s['icon'] === 'radiate'}
                            <svg width="36" height="36" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" class="text-parch-primary" aria-hidden="true"><circle cx="24" cy="24" r="3" fill="currentColor"/><circle cx="24" cy="24" r="9" opacity="0.65"/><circle cx="24" cy="24" r="15" opacity="0.35"/><circle cx="24" cy="24" r="21" opacity="0.18"/></svg>
                        {else}
                            <svg width="36" height="36" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" class="text-parch-primary" aria-hidden="true"><circle cx="24" cy="10" r="3"/><circle cx="10" cy="32" r="3"/><circle cx="38" cy="32" r="3"/><circle cx="17" cy="38" r="3"/><circle cx="31" cy="38" r="3"/><path d="M24 13l-12 17M24 13l12 17M12 33l5 4M36 33l-5 4M14 32h22"/></svg>
                        {/if}
                    </div>

                    <div class="font-mono text-[10px] uppercase tracking-widest2 text-parch-tertiary mb-2 tabular-nums">Step {$s['n']}</div>
                    <h3 class="font-display text-[19px] tracking-tighter text-parch-primary mb-3 leading-tight">{$s['title']}</h3>
                    <p class="text-parch-secondary text-[13.5px] leading-[1.65]">{$s['body']}</p>

                    {* Connector arrow on desktop, between steps *}
                    {if $i < 3}
                        <span class="hidden lg:flex absolute right-[-12px] top-12 w-6 h-6 items-center justify-center bg-cream-base text-parch-dim z-10" aria-hidden="true">
                            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M1 5h12m0 0L9 1m4 4L9 9"/></svg>
                        </span>
                    {/if}
                </article>
            {/foreach}
        </div>

    </div>
</section>

{* ============================================ TICKER · recent IMM IDs ===== *}
{var $tickerIds = [
  'IMM-2026-0312', 'IMM-2026-0311', 'IMM-2026-0310', 'IMM-2026-0309', 'IMM-2026-0308',
  'IMM-2026-0307', 'IMM-2026-0306', 'IMM-2026-0305', 'IMM-2026-0304', 'IMM-2026-0303',
  'IMM-2026-0301', 'IMM-2026-0299', 'IMM-2026-0298', 'IMM-2026-0296', 'IMM-2026-0295',
  'IMM-2026-0293', 'IMM-2026-0291', 'IMM-2026-0290', 'IMM-2026-0289', 'IMM-2026-0287',
  'IMM-2026-0285', 'IMM-2026-0284', 'IMM-2026-0283', 'IMM-2026-0276', 'IMM-2026-0271',
  'IMM-2026-0263',
]}
<aside class="relative bg-ink-base border-y border-ink-line/60 overflow-hidden" aria-label="Recently published antibodies">
    <div class="ticker-track py-4 select-none">
        {* Two identical lists side-by-side make the loop seamless *}
        {for $pass = 0; $pass < 2; $pass++}
            <ul class="flex items-center gap-10 px-5" aria-hidden="{$pass === 1 ? 'true' : 'false'}">
                {foreach $tickerIds as $id}
                    <li>
                        <a href="/antibody/{$id}" class="font-mono text-[12px] text-fg-tertiary hover:text-accent transition-colors tabular-nums whitespace-nowrap inline-flex items-center gap-2">
                            <span class="inline-flex h-1 w-1 rounded-full bg-immune-500/70" aria-hidden="true"></span>
                            {$id}
                        </a>
                    </li>
                {/foreach}
            </ul>
        {/for}
    </div>
</aside>

{* ============================================ 03 · LIVE ACTIVITY ===== *}
{var $events = [
  ['kind' => 'mint',      'verb' => 'published', 'proto' => 'mint',     'id' => 'IMM-2026-0312', 'when' => '23s ago', 'desc' => 'SEMANTIC pattern, 87% confidence, "approve unlimited spend"', 'meta' => 'by huntress.eth'],
  ['kind' => 'block',     'verb' => 'protected', 'proto' => 'block',    'id' => 'IMM-2026-0287', 'when' => '47s ago', 'desc' => '$4,200 protected, swap on Uniswap v4 / Sepolia hook',         'meta' => 'tx 0x9af3..2c1e'],
  ['kind' => 'mirror',    'verb' => 'synced',    'proto' => 'mirror',   'id' => 'IMM-2026-0301', 'when' => '1m ago',  'desc' => 'propagated to Base, Optimism, Arbitrum (3 chains)',          'meta' => 'relayer 0x4a..91c2'],
  ['kind' => 'mint',      'verb' => 'published', 'proto' => 'mint',     'id' => 'IMM-2026-0298', 'when' => '2m ago',  'desc' => 'ADDRESS, drainer wallet flagged from 7 prior matches',       'meta' => 'by scout.eth'],
  ['kind' => 'challenge', 'verb' => 'challenged','proto' => 'challenge','id' => 'IMM-2026-0276', 'when' => '4m ago',  'desc' => 'counter-stake 1.5 USDC, claim: "legitimate dex aggregator"',  'meta' => 'by 0x6f1c..bd80'],
  ['kind' => 'mint',      'verb' => 'published', 'proto' => 'mint',     'id' => 'IMM-2026-0289', 'when' => '6m ago',  'desc' => 'CALL_PATTERN, approve(MAX_UINT256, 0xbad..1234)',             'meta' => 'by sentinel.eth'],
  ['kind' => 'block',     'verb' => 'protected', 'proto' => 'block',    'id' => 'IMM-2026-0271', 'when' => '9m ago',  'desc' => '$890 protected, swap intercepted before signature',          'meta' => 'tx 0x42c9..d4f7'],
  ['kind' => 'expire',    'verb' => 'released',  'proto' => 'expire',   'id' => 'IMM-2026-0263', 'when' => '12m ago', 'desc' => '72h stake released, 0 challenges, +0.41 USDC to publisher',  'meta' => 'by sentinel.eth'],
]}
{var $filters = [
  ['key' => 'all',       'label' => 'All',        'count' => count($events)],
  ['key' => 'mint',      'label' => 'Published',  'count' => 3],
  ['key' => 'block',     'label' => 'Protected',  'count' => 2],
  ['key' => 'mirror',    'label' => 'Synced',     'count' => 1],
  ['key' => 'challenge', 'label' => 'Disputed',   'count' => 1],
  ['key' => 'expire',    'label' => 'Released',   'count' => 1],
]}

<section class="relative bg-ink-base">
    <div class="max-w-[1400px] mx-auto px-7 pt-20 pb-16">

        <div class="flex flex-wrap items-end justify-between gap-6 mb-8">
            <div>
                <div class="flex items-center gap-3 mb-3">
                    <span class="font-mono text-[10.5px] text-fg-tertiary tabular-nums">03</span>
                    <span class="font-mono text-[10.5px] text-fg-dim">·</span>
                    <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Live activity</span>
                    <span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
                    <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-dim">Live · updating every 4s</span>
                </div>
                <h2 class="font-display text-[34px] font-light tracking-tighter text-fg-primary leading-[1.05]">
                    The network is breathing.
                </h2>
                <p class="text-fg-secondary text-[14px] leading-[1.6] mt-3 max-w-[520px]">
                    Every event below is a real artifact: signed, staked, and addressable forever. Click any IMM ID to inspect.
                </p>
            </div>
            <a href="/dashboard" class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary hover:text-fg-primary transition-colors inline-flex items-center gap-1.5 self-start">
                Open dashboard
                <svg width="11" height="11" viewBox="0 0 12 12" aria-hidden="true"><path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>
            </a>
        </div>

        {* Filter chips *}
        <div class="flex flex-wrap items-center gap-2 mb-6 pb-5 border-b border-ink-line/40">
            {foreach $filters as $f}
                {var $active = $f['key'] === 'all'}
                <button data-filter="{$f['key']}"
                        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-sm border font-mono text-[10.5px] uppercase tracking-widest2 transition-colors
                               {$active ? 'border-accent/40 bg-accent/10 text-accent' : 'border-ink-line/60 text-fg-tertiary hover:text-fg-secondary hover:border-fg-tertiary'}">
                    {$f['label']}
                    <span class="text-fg-dim tabular-nums normal-case tracking-normal">{$f['count']}</span>
                </button>
            {/foreach}
        </div>

        <div class="border-t border-ink-line/60">
            {foreach $events as $i => $e}
                {var $dotTone = match($e['kind']) {
                    'mint'      => 'bg-accent',
                    'block'     => 'bg-immune-500',
                    'mirror'    => 'bg-fg-tertiary',
                    'challenge' => 'bg-caution-500',
                    'expire'    => 'bg-fg-dim',
                }}
                {var $isLast = $i === count($events) - 1}
                <a href="/antibody/{$e['id']}" data-event="{$e['kind']}"
                   class="grid grid-cols-[14px_64px_148px_140px_1fr_200px] gap-4 items-center py-3.5 {$isLast ? '' : 'border-b border-ink-line/40'} hover:bg-ink-elevated/40 transition-colors group">
                    <span class="inline-flex h-1.5 w-1.5 rounded-full {$dotTone}" aria-label="{$e['kind']}"></span>
                    <span class="font-mono text-[11px] text-fg-tertiary tabular-nums">{$e['when']}</span>
                    <span class="font-mono text-[12px] text-fg-primary group-hover:text-accent transition-colors">{$e['id']}</span>
                    <span class="flex items-baseline gap-2">
                        <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-secondary">{$e['verb']}</span>
                        <span class="font-mono text-[9.5px] uppercase tracking-widest2 text-fg-dim normal-case lowercase">{$e['proto']}</span>
                    </span>
                    <span class="text-fg-secondary text-[13.5px] truncate">{$e['desc']}</span>
                    <span class="font-mono text-[11px] text-fg-tertiary text-right truncate">{$e['meta']}</span>
                </a>
            {/foreach}
        </div>

        <p class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-dim mt-6">
            Verbs are the friendly name. The smaller word below each is the protocol term.
        </p>

    </div>
</section>

{* ============================================ 04 · ARCHITECTURE ===== *}
<section class="relative bg-ink-elevated/30 border-y border-ink-line/60">
    <div class="relative max-w-[1400px] mx-auto px-7 py-24">

        <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[10.5px] text-fg-tertiary tabular-nums">04</span>
            <span class="font-mono text-[10.5px] text-fg-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Architecture</span>
        </div>
        <h2 class="font-display text-[34px] font-light tracking-tighter text-fg-primary leading-[1.05] mb-12 max-w-[720px]">
            Three layers, one protocol.
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-[1080px]">
            <div>
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Speed layer</div>
                <h3 class="font-display text-[20px] tracking-tighter text-fg-primary mb-2">Gossip in seconds</h3>
                <p class="text-fg-secondary text-[14px] leading-[1.65]">Antibodies fan out across the AXL mesh through signed pub/sub topics. Every agent's local cache updates in well under one second.</p>
            </div>
            <div>
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Trust layer</div>
                <h3 class="font-display text-[20px] tracking-tighter text-fg-primary mb-2">Staked on chain</h3>
                <p class="text-fg-secondary text-[14px] leading-[1.65]">Each publisher locks 1 USDC for 72 hours. Match rewards split 70 / 20 / 10. False positives are challengeable. Skin in the game by design.</p>
            </div>
            <div>
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-3">Verification layer</div>
                <h3 class="font-display text-[20px] tracking-tighter text-fg-primary mb-2">Sealed evidence</h3>
                <p class="text-fg-secondary text-[14px] leading-[1.65]">Detection runs in a 0G Compute TEE. Verdicts carry attestation hashes. The original context is encrypted to the enclave key and never shown.</p>
            </div>
        </div>
    </div>
</section>

{* ============================================ 05 · FOR DEVELOPERS ===== *}
<section class="relative bg-cream-base text-parch-primary">
    <div class="absolute inset-0 dot-bg-light opacity-50 pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-[1400px] mx-auto px-7 py-24">

        <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[10.5px] text-parch-tertiary tabular-nums">05</span>
            <span class="font-mono text-[10.5px] text-parch-dim">·</span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-parch-tertiary">For developers</span>
        </div>
        <h2 class="font-display text-[40px] font-light tracking-tighter leading-[1.05] mb-4 max-w-[720px]">
            One call before any agent action.
        </h2>
        <p class="text-parch-secondary text-[15.5px] leading-[1.65] max-w-[640px] mb-14">
            The SDK is a single import. Pass any tx or context to <code class="font-mono text-[14px]">immunity.check()</code> and the network responds with a verdict, evidence, and matching antibodies before you sign.
        </p>

        <div class="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-10 items-start">

            {* Code sample with window chrome *}
            <div class="border border-cream-line rounded-sm bg-cream-elevated overflow-hidden shadow-sm">
                <header class="flex items-center justify-between gap-3 px-4 py-2.5 border-b border-cream-line bg-cream-sunken">
                    <div class="flex items-center gap-2">
                        <span class="inline-flex h-2.5 w-2.5 rounded-full bg-threat-300/70" aria-hidden="true"></span>
                        <span class="inline-flex h-2.5 w-2.5 rounded-full bg-caution-300/70" aria-hidden="true"></span>
                        <span class="inline-flex h-2.5 w-2.5 rounded-full bg-immune-300/70" aria-hidden="true"></span>
                    </div>
                    <span class="font-mono text-[11px] text-parch-tertiary">agent.ts</span>
                    <button data-copy-btn="#sdk-code" class="font-mono text-[10px] uppercase tracking-widest2 text-parch-tertiary hover:text-parch-primary transition-colors inline-flex items-center gap-1.5"
                            aria-label="Copy code">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                        <span data-copy-label>Copy</span>
                    </button>
                </header>
                {syntax off}
                <pre id="sdk-code" class="font-mono text-[12.5px] leading-[1.7] px-5 py-5 overflow-x-auto m-0"><code><span class="text-threat-700">import</span> <span class="text-parch-primary">{ Immunity }</span> <span class="text-threat-700">from</span> <span class="text-immune-700">"@immunity/sdk"</span><span class="text-parch-tertiary">;</span>

<span class="text-threat-700">const</span> immunity <span class="text-parch-tertiary">=</span> <span class="text-threat-700">new</span> <span class="text-caution-700">Immunity</span><span class="text-parch-tertiary">({</span>
  wallet<span class="text-parch-tertiary">,</span>
  network<span class="text-parch-tertiary">:</span> <span class="text-immune-700">"mainnet"</span>
<span class="text-parch-tertiary">});</span>

<span class="text-parch-tertiary">// Before any agent action</span>
<span class="text-threat-700">const</span> result <span class="text-parch-tertiary">=</span> <span class="text-threat-700">await</span> immunity<span class="text-parch-tertiary">.</span><span class="text-caution-700">check</span><span class="text-parch-tertiary">(</span>tx<span class="text-parch-tertiary">,</span> context<span class="text-parch-tertiary">);</span>

<span class="text-threat-700">if</span> <span class="text-parch-tertiary">(</span>result<span class="text-parch-tertiary">.</span>decision <span class="text-parch-tertiary">===</span> <span class="text-immune-700">"block"</span><span class="text-parch-tertiary">)</span> <span class="text-parch-tertiary">{</span>
  console<span class="text-parch-tertiary">.</span><span class="text-caution-700">warn</span><span class="text-parch-tertiary">(</span><span class="text-immune-700">"Blocked:"</span><span class="text-parch-tertiary">,</span> result<span class="text-parch-tertiary">.</span>antibodies<span class="text-parch-tertiary">[</span><span class="text-caution-700">0</span><span class="text-parch-tertiary">].</span>immId<span class="text-parch-tertiary">);</span>
  <span class="text-threat-700">return</span><span class="text-parch-tertiary">;</span>
<span class="text-parch-tertiary">}</span>

<span class="text-threat-700">if</span> <span class="text-parch-tertiary">(</span>result<span class="text-parch-tertiary">.</span>decision <span class="text-parch-tertiary">===</span> <span class="text-immune-700">"escalate"</span><span class="text-parch-tertiary">)</span> <span class="text-parch-tertiary">{</span>
  <span class="text-threat-700">await</span> <span class="text-caution-700">notifyOperator</span><span class="text-parch-tertiary">(</span>result<span class="text-parch-tertiary">);</span>
  <span class="text-threat-700">return</span><span class="text-parch-tertiary">;</span>
<span class="text-parch-tertiary">}</span>

<span class="text-parch-tertiary">// Safe to proceed</span>
<span class="text-threat-700">await</span> wallet<span class="text-parch-tertiary">.</span><span class="text-caution-700">sendTransaction</span><span class="text-parch-tertiary">(</span>tx<span class="text-parch-tertiary">);</span></code></pre>
                {/syntax}
            </div>

            {* Bullets + CTA *}
            <div>
                <div class="font-mono text-[10px] uppercase tracking-widest2 text-parch-tertiary mb-5">What you get</div>
