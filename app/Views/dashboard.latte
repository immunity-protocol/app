{layout 'layouts/main.latte'}

{block title}Dashboard / Immunity network{/block}

{block head}
<script defer src="{asset('/javascripts/propagation-map.js')}"></script>
<script>
window.addEventListener('DOMContentLoaded', () => {
  const el = document.getElementById('dash-map');
  if (el && window.PropagationMap) {
    window.__dashMap = new window.PropagationMap(el, {
      nodeCount: 60,
      nodeRadius: 4.5,
      autoFire: false,
    });
  }
  // Click an agent row -> pulse its node on the map. Delegated so it
  // continues to work after the activity poller swaps row content.
  document.addEventListener('click', function (ev) {
    const row = ev.target.closest && ev.target.closest('[data-agent-row]');
    if (!row || !window.__dashMap) return;
    window.__dashMap.triggerWaveAt(row.getAttribute('data-agent-row'));
  });
});
</script>
{/block}

{block content}

<section class="max-w-[1400px] mx-auto px-7 pt-10 pb-6">

    {* ============== DEMO BANNER ==============
       The dashboard reflects the live showcase fleet, not production
       network telemetry. Stays visible at the very top of the page so
       a judge or first-time visitor knows what they're looking at. *}
    <div class="mb-8 px-4 py-2.5 border border-caution-500/30 bg-caution-500/5 rounded-sm flex items-start gap-3">
        <span class="font-mono text-[10px] uppercase tracking-widest2 text-caution-500 shrink-0 mt-0.5">Demo console</span>
        <span class="text-[13px] text-fg-secondary leading-[1.55]">
            Data here is from the active showcase fleet, not production network telemetry.
            For the canonical antibody registry see the <a href="/antibodies" class="text-accent-soft hover:text-accent transition-colors underline-offset-4 hover:underline">explorer</a>.
        </span>
    </div>

    {* ============== PAGE HEADER ============== *}
    <header class="flex items-end justify-between gap-8">
        <div class="min-w-0">
            <div class="flex items-center gap-3 mb-3">
                <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Network</span>
                <span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
                <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-immune-500">Live</span>
            </div>
            <h1 class="font-display text-[60px] font-light tracking-tightest text-fg-primary leading-[1.0]">
                Dashboard
            </h1>
            <p class="text-fg-secondary text-[15px] mt-4 max-w-[640px] leading-[1.6]">
                Real-time view of antibody propagation, registry activity, and the demo agent fleet.
            </p>
        </div>
        <div class="text-right shrink-0 flex flex-col items-end gap-2">
            <a href="/playground" class="inline-flex items-center gap-1.5 font-mono text-[10.5px] uppercase tracking-widest2 text-accent-soft hover:text-accent transition-colors">
                Open playground
                <svg width="11" height="11" viewBox="0 0 12 12" aria-hidden="true"><path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>
            </a>
            <span class="font-mono text-[10px] uppercase tracking-widest2 text-fg-dim">drive the fleet</span>
        </div>
    </header>
</section>

{* ============== STATS BAR ============== *
   Full-width breakout matching the playground status bar pattern: deeper
   dark background, inline divider lines, big monospace numbers. Same data
   source as the nav badge (/api/v1/network/stats) so the existing live
   poller keeps the values fresh without a page refresh. *}
<section class="relative bg-ink-sunken border-y border-ink-line/60">
    <div class="relative max-w-[1400px] mx-auto px-7 py-6">
        <div class="flex items-center gap-3 mb-5">
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Network status</span>
            <span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
            <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-immune-500">live</span>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-5 gap-y-6 md:gap-0">

            <div class="md:px-7 md:first:pl-0 md:border-r md:border-ink-line/60">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-2">Agents online</div>
                <div data-stat="agents_online" class="font-display text-[44px] font-light tracking-tighter text-immune-500 leading-none tabular-nums">-</div>
                <div class="font-mono text-[11px] text-fg-tertiary tabular-nums mt-3"><span data-agent-total-strip>{count($agents ?? [])}</span> in fleet</div>
            </div>

            <div class="md:px-7 md:border-r md:border-ink-line/60">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-2">Antibodies active</div>
                <div data-stat="antibodies_active" class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">-</div>
                <div class="font-mono text-[11px] text-immune-500 tabular-nums mt-3" data-delta="antibodies_active">&nbsp;</div>
            </div>

            <div class="md:px-7 md:border-r md:border-ink-line/60">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-2">Cache hits / hr</div>
                <div data-stat="cache_hits_per_hour" class="font-display text-[44px] font-light tracking-tighter text-fg-primary leading-none tabular-nums">-</div>
                <div class="font-mono text-[11px] text-immune-500 tabular-nums mt-3" data-delta="cache_hits_per_hour">&nbsp;</div>
            </div>

            <div class="md:px-7 md:border-r md:border-ink-line/60">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-2">LLM calls saved</div>
                <div data-stat="llm_calls_saved" class="font-display text-[44px] font-light tracking-tighter text-threat-300 leading-none tabular-nums">-</div>
                <div class="font-mono text-[11px] text-fg-tertiary mt-3">
                    <span class="text-immune-500" data-compute-saved="llm_calls_saved">≈ $0</span> in compute
                </div>
            </div>

            <div class="md:px-7">
                <div class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary mb-2">Value protected</div>
                <div data-stat-money="value_protected_usd" class="font-display text-[44px] font-light tracking-tighter text-accent-soft leading-none tabular-nums">-</div>
                <div class="font-mono text-[11px] text-immune-500 tabular-nums mt-3" data-delta-money="value_protected_usd">&nbsp;</div>
            </div>

        </div>
    </div>
</section>

<section class="max-w-[1400px] mx-auto px-7 pt-10 pb-16">

    {* ============== MAP + DUAL FEED (filled in 7c, 7d, 7e) ============== *}
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-10 mb-10">

        {* Propagation map + agent detail *}
        <div class="border border-ink-line/60 rounded-sm bg-ink-elevated/20 p-7 flex flex-col gap-4">

            <header class="flex items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Propagation map</span>
                    <span class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-widest2 text-immune-500">
                        <span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
                        60 nodes
                    </span>
                </div>
                <div class="flex items-center gap-4 font-mono text-[10px] uppercase tracking-widest2 text-fg-dim">
                    <span class="inline-flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>Publisher</span>
                    <span class="inline-flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-immune-500" aria-hidden="true"></span>Receiver</span>
                    <span class="inline-flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-fg-dim" aria-hidden="true"></span>Offline</span>
                </div>
            </header>

            <div id="dash-map" class="relative w-full aspect-square max-w-[640px] mx-auto" aria-label="Live agent propagation map"></div>
        </div>

        {* ============== AGENT LIST ==============
           Full demo fleet roster, scrollable, server-rendered for first
           paint. The dashboard activity poll updates each row in place
           every 2s so dot color, last-seen, and 24h counters stay live
           without losing the scroll position.

           Click a row -> the corresponding node on the propagation map
           pulses, so an operator can find any agent visually. *}
        <aside class="border border-ink-line/60 rounded-sm bg-ink-elevated/20 flex flex-col" data-agent-panel>
            <header class="px-5 py-3 border-b border-ink-line/40 flex items-center justify-between gap-2 shrink-0">
                <div class="flex items-center gap-2.5">
                    <span class="inline-flex h-1.5 w-1.5 rounded-full bg-immune-500 pulse-soft" aria-hidden="true"></span>
                    <span class="font-mono text-[10px] uppercase tracking-widest2 text-immune-500">Agent fleet</span>
                </div>
                <span class="font-mono text-[10px] text-fg-dim"><span data-agent-online-count>0</span> / <span data-agent-total-count>{count($agents ?? [])}</span> online</span>
            </header>
            <ul class="divide-y divide-ink-line/30 overflow-y-auto max-h-[640px]" data-agent-list>
            {if count($agents ?? []) === 0}
                <li class="px-5 py-8 text-center font-mono text-[11px] text-fg-dim italic">
                    No agents heartbeating. Start the demo fleet to populate this list.
                </li>
            {/if}
            {foreach $agents ?? [] as $a}
                {var $online = (bool) $a->online}
                {var $roleUpper = strtoupper((string) $a->role)}
                {var $roleTone = match($roleUpper) {
                    'TRADER'    => 'text-fg-secondary',
                    'WOLF'      => 'text-threat-300',
                    'PUBLISHER' => 'text-accent-soft',
                    'WATCHER'   => 'text-immune-300',
                    'SCENARIO'  => 'text-caution-300',
                    default     => 'text-fg-tertiary',
                }}
                {var $displayName = trim((string) $a->display_name) !== '' ? $a->display_name : $a->agent_id}
                <li data-agent-row="{$a->agent_id}" class="px-5 py-2.5 flex items-center gap-3 hover:bg-ink-elevated/40 transition-colors cursor-pointer">
                    <span class="inline-flex h-1.5 w-1.5 rounded-full shrink-0 {if $online}bg-immune-500{else}bg-fg-dim{/if}" aria-hidden="true" data-agent-dot></span>
                    <span class="font-mono text-[11.5px] text-fg-primary truncate flex-1 min-w-0" data-agent-name>{$displayName}</span>
                    <span class="font-mono text-[9px] uppercase tracking-widest2 {$roleTone} shrink-0" data-agent-role>{$roleUpper}</span>
                    <span class="font-mono text-[10.5px] text-fg-secondary tabular-nums shrink-0 w-10 text-right" data-agent-checks title="Checks in the last 24h">{(int) $a->checks_24h}</span>
                    <span class="font-mono text-[10.5px] tabular-nums shrink-0 w-10 text-right {if $a->blocks_24h > 0}text-threat-300{else}text-fg-dim{/if}" data-agent-blocks title="Blocks in the last 24h">{(int) $a->blocks_24h}</span>
                    <span class="font-mono text-[10px] text-fg-dim shrink-0 w-14 text-right" data-agent-seen>{format('timeago', $a->last_seen)}</span>
                </li>
            {/foreach}
            </ul>
        </aside>
    </div>

    {* ============== ACTIVE REGISTRY ==============
       Latest 10 antibodies with per-row stats (cache_hits, value_protected,
       mirror_count, last_block_at). Server-rendered for first paint;
       /api/v1/dashboard/activity poll keeps it live in subsequent ticks. *}

    <section class="border border-ink-line/60 rounded-sm bg-ink-elevated/20">

        <header class="px-7 py-4 border-b border-ink-line/40 flex items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <span class="font-mono text-[10.5px] uppercase tracking-widest2 text-fg-tertiary">Active registry</span>
                <span class="font-mono text-[10px] text-fg-dim">latest 10 published</span>
            </div>
            <a href="/antibodies" class="font-mono text-[10px] uppercase tracking-widest2 text-fg-secondary hover:text-accent transition-colors inline-flex items-center gap-1.5">
                Browse all
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
            </a>
        </header>

        <table class="w-full" data-registry-table>
            <thead>
                <tr class="border-b border-ink-line/40 bg-ink-sunken/30">
                    <th class="font-mono text-[9.5px] uppercase tracking-widest2 text-fg-tertiary font-normal text-left pl-7 pr-4 py-3">IMM ID</th>
                    <th class="font-mono text-[9.5px] uppercase tracking-widest2 text-fg-tertiary font-normal text-left pr-4 py-3">Type</th>
                    <th class="font-mono text-[9.5px] uppercase tracking-widest2 text-fg-tertiary font-normal text-left pr-6 py-3">Reasoning</th>
                    <th class="font-mono text-[9.5px] uppercase tracking-widest2 text-fg-tertiary font-normal text-left pr-4 py-3">Publisher</th>
                    <th class="font-mono text-[9.5px] uppercase tracking-widest2 text-fg-tertiary font-normal text-right pr-4 py-3">Hits</th>
                    <th class="font-mono text-[9.5px] uppercase tracking-widest2 text-fg-tertiary font-normal text-right pr-4 py-3">Value protected</th>
                    <th class="font-mono text-[9.5px] uppercase tracking-widest2 text-fg-tertiary font-normal text-right pr-7 py-3">Last block</th>
                </tr>
            </thead>
            <tbody data-registry-body>
            {if count($recentAntibodies ?? []) === 0}
                <tr><td colspan="7" class="px-7 py-8 text-center font-mono text-[11.5px] text-fg-dim">
                    No antibodies published yet. Rows will appear as the fleet publishes new threats.
                </td></tr>
            {/if}
            {foreach $recentAntibodies ?? [] as $r}
                {var $typeUpper = strtoupper($r->type)}
                {var $typeColor = match($typeUpper) {
                    'ADDRESS'      => 'text-fg-secondary',
                    'CALL_PATTERN' => 'text-caution-300',
                    'BYTECODE'     => 'text-immune-300',
                    'GRAPH'        => 'text-accent-soft',
                    default        => 'text-threat-300',
                }}
                {var $reasoning = trim((string) ($r->redacted_reasoning ?? '')) !== ''
                    ? trim((string) $r->redacted_reasoning)
                    : 'no reasoning recorded'}
                {var $reasoningTrunc = mb_strlen($reasoning) > 70 ? mb_substr($reasoning, 0, 68) . '…' : $reasoning}
                {var $publisherDisplay = $r->publisher_ens
                    ?? ('0x' . substr($r->publisher_hex, 0, 6) . '…' . substr($r->publisher_hex, -4))}
                {var $isHexPub = $r->publisher_ens === null}
                <tr data-registry-row="{$r->imm_id}" class="border-b border-ink-line/30 last:border-0 hover:bg-ink-elevated/30 transition-colors group align-middle">
                    <td class="pl-7 pr-4 py-3 align-middle">
                        <a href="/antibody/{$r->imm_id}" class="font-mono text-[12.5px] text-fg-primary group-hover:text-accent transition-colors">{$r->imm_id}</a>
                    </td>
                    <td class="pr-4 py-3 align-middle">
                        <span class="font-mono text-[10.5px] uppercase tracking-widest2 {$typeColor}">{$typeUpper}</span>
                    </td>
                    <td class="pr-6 py-3 max-w-[320px] align-middle">
                        <span class="text-[12.5px] text-fg-secondary truncate inline-block max-w-full" title="{$reasoning}">{$reasoningTrunc}</span>
                    </td>
                    <td class="pr-4 py-3 align-middle">
                        <span class="{$isHexPub ? 'font-mono text-[11.5px] text-fg-secondary' : 'text-[12.5px] text-fg-secondary'}">{$publisherDisplay}</span>
                    </td>
                    <td class="pr-4 py-3 text-right font-mono text-[12px] text-fg-primary tabular-nums align-middle">{format('decimal', $r->cache_hits, 0)}</td>
                    <td class="pr-4 py-3 text-right font-mono text-[12px] text-immune-500 tabular-nums align-middle">{format('money', $r->value_protected_usd)}</td>
                    <td class="pr-7 py-3 text-right font-mono text-[11px] text-fg-tertiary tabular-nums align-middle">
                        {if $r->last_block_at}{format('timeago', $r->last_block_at)}{else}-{/if}
                    </td>
                </tr>
            {/foreach}
            </tbody>
        </table>

    </section>

</section>

<script src="{asset('/javascripts/live.js')}"></script>
<script>
(function () {
  function fmtNumber(v) {
    if (v === null || v === undefined || v === '') return '-';
    const n = Number(v);
    return Number.isFinite(n) ? n.toLocaleString('en-US', { maximumFractionDigits: 0 }) : '-';
  }
  function fmtMoney(v) {
    if (v === null || v === undefined || v === '') return '-';
    const n = Number(v);
    return Number.isFinite(n) ? '$' + n.toLocaleString('en-US', { maximumFractionDigits: 0 }) : '-';
  }
  function fmtDelta(v, money) {
    if (v === null || v === undefined || v === '') return ' ';
    const n = Number(v);
    if (!Number.isFinite(n)) return ' ';
    const sign = n >= 0 ? '+' : '-';
    return sign + (money ? '$' : '') + Math.abs(n).toLocaleString('en-US', { maximumFractionDigits: 0 }) + ' in 1h';
  }
  Live.poll('/api/v1/network/stats', 4000, function (data) {
    const tiles = data.tiles || {};
    document.querySelectorAll('[data-stat]').forEach(function (el) {
      const m = el.getAttribute('data-stat');
      if (tiles[m]) el.textContent = fmtNumber(tiles[m].value);
    });
    document.querySelectorAll('[data-stat-money]').forEach(function (el) {
      const m = el.getAttribute('data-stat-money');
      if (tiles[m]) el.textContent = fmtMoney(tiles[m].value);
    });
    document.querySelectorAll('[data-delta]').forEach(function (el) {
      const m = el.getAttribute('data-delta');
      if (tiles[m]) el.textContent = fmtDelta(tiles[m].delta_1h, false);
    });
    document.querySelectorAll('[data-delta-money]').forEach(function (el) {
      const m = el.getAttribute('data-delta-money');
      if (tiles[m]) el.textContent = fmtDelta(tiles[m].delta_1h, true);
    });
    // 0G Compute pricing for qwen-2.5-7b-instruct: ~$0.0001 per call.
    // Cumulative since registry deploy.
    document.querySelectorAll('[data-compute-saved]').forEach(function (el) {
      const m = el.getAttribute('data-compute-saved');
      const tile = tiles[m];
      if (!tile) return;
      const n = Number(tile.value);
      if (!Number.isFinite(n) || n <= 0) { el.textContent = '≈ $0'; return; }
      const usd = n * 0.0001;
      if (usd < 0.01) el.textContent = '≈ <$0.01';
      else if (usd < 1) el.textContent = '≈ $' + usd.toFixed(2);
      else el.textContent = '≈ $' + usd.toLocaleString('en-US', { maximumFractionDigits: 0 });
    });
  });
})();

// ============================================================================
// Dashboard activity poll: drives the propagation map, agent list, and the
// active-registry table from one coordinated tick every 2s. Pauses when the
// tab is hidden so we don't burn CPU in background tabs.
// ============================================================================
(function () {
  let agentMapBound = false;
  let cursor = null;

  function bindAgentMap(agents) {
    if (agentMapBound || !window.__dashMap || agents.length === 0) return;
    // Sorted alphabetically by agent_id so node positions are deterministic
    // across reloads (the server already returns this order, but we sort
    // defensively in case a future endpoint shuffles them).
    const ids = agents.map(function (a) { return a.agent_id; }).sort();
    window.__dashMap.setAgentMap(ids);
    agentMapBound = true;
  }

  function applyOnlineSet(agents) {
    if (!window.__dashMap) return;
    const online = agents.filter(function (a) { return a.online; })
                         .map(function (a) { return a.agent_id; });
    window.__dashMap.setOnlineSet(online);
  }

  // ---------------- Agent list live update ----------------

  const ROLE_TONE = {
    'TRADER':    'text-fg-secondary',
    'WOLF':      'text-threat-300',
    'PUBLISHER': 'text-accent-soft',
    'WATCHER':   'text-immune-300',
    'SCENARIO':  'text-caution-300',
  };

  function updateAgentRow(agent) {
    const row = document.querySelector('[data-agent-row="' + CSS.escape(agent.agent_id) + '"]');
    if (!row) return;
    const dot = row.querySelector('[data-agent-dot]');
    if (dot) {
      dot.classList.remove('bg-immune-500', 'bg-fg-dim');
      dot.classList.add(agent.online ? 'bg-immune-500' : 'bg-fg-dim');
    }
    const nameEl = row.querySelector('[data-agent-name]');
    if (nameEl) {
      const display = agent.display_name && agent.display_name.trim() !== ''
        ? agent.display_name : agent.agent_id;
      if (nameEl.textContent !== display) nameEl.textContent = display;
    }
    const roleEl = row.querySelector('[data-agent-role]');
    if (roleEl) {
      const roleUpper = String(agent.role || '').toUpperCase();
      roleEl.textContent = roleUpper;
      const tone = ROLE_TONE[roleUpper] || 'text-fg-tertiary';
      ['text-fg-secondary', 'text-threat-300', 'text-accent-soft',
       'text-immune-300', 'text-caution-300', 'text-fg-tertiary']
        .forEach(function (c) { roleEl.classList.remove(c); });
      roleEl.classList.add(tone);
    }
    const checksEl = row.querySelector('[data-agent-checks]');
    if (checksEl) checksEl.textContent = String(agent.checks_24h);
    const blocksEl = row.querySelector('[data-agent-blocks]');
    if (blocksEl) {
      blocksEl.textContent = String(agent.blocks_24h);
      blocksEl.classList.remove('text-threat-300', 'text-fg-dim');
      blocksEl.classList.add(agent.blocks_24h > 0 ? 'text-threat-300' : 'text-fg-dim');
    }
    const seenEl = row.querySelector('[data-agent-seen]');
    if (seenEl) seenEl.textContent = timeAgo(agent.last_seen);
  }

  function appendAgentRow(agent) {
    const list = document.querySelector('[data-agent-list]');
    if (!list) return;
    // Drop the empty-state row if it's still there.
    const empty = list.querySelector('li.italic');
    if (empty) empty.remove();
    const li = document.createElement('li');
    li.setAttribute('data-agent-row', agent.agent_id);
    li.className = 'px-5 py-2.5 flex items-center gap-3 hover:bg-ink-elevated/40 transition-colors cursor-pointer';
    const roleUpper = String(agent.role || '').toUpperCase();
    const tone = ROLE_TONE[roleUpper] || 'text-fg-tertiary';
    const display = agent.display_name && agent.display_name.trim() !== ''
      ? agent.display_name : agent.agent_id;
    const blockTone = agent.blocks_24h > 0 ? 'text-threat-300' : 'text-fg-dim';
    const dotTone = agent.online ? 'bg-immune-500' : 'bg-fg-dim';
    li.innerHTML =
      '<span class="inline-flex h-1.5 w-1.5 rounded-full shrink-0 ' + dotTone + '" aria-hidden="true" data-agent-dot></span>' +
      '<span class="font-mono text-[11.5px] text-fg-primary truncate flex-1 min-w-0" data-agent-name>' + escapeHtml(display) + '</span>' +
      '<span class="font-mono text-[9px] uppercase tracking-widest2 ' + tone + ' shrink-0" data-agent-role>' + escapeHtml(roleUpper) + '</span>' +
      '<span class="font-mono text-[10.5px] text-fg-secondary tabular-nums shrink-0 w-10 text-right" data-agent-checks>' + agent.checks_24h + '</span>' +
      '<span class="font-mono text-[10.5px] tabular-nums shrink-0 w-10 text-right ' + blockTone + '" data-agent-blocks>' + agent.blocks_24h + '</span>' +
      '<span class="font-mono text-[10px] text-fg-dim shrink-0 w-14 text-right" data-agent-seen>' + timeAgo(agent.last_seen) + '</span>';
    list.appendChild(li);
  }

  function updateAgentList(agents) {
    const list = document.querySelector('[data-agent-list]');
    if (!list || !Array.isArray(agents)) return;
    let onlineCount = 0;
    agents.forEach(function (a) {
      if (a.online) onlineCount++;
      const existing = list.querySelector('[data-agent-row="' + CSS.escape(a.agent_id) + '"]');
      if (existing) updateAgentRow(a);
      else appendAgentRow(a);
    });
    const totalEl = document.querySelector('[data-agent-total-count]');
    if (totalEl) totalEl.textContent = String(agents.length);
    const onlineEl = document.querySelector('[data-agent-online-count]');
    if (onlineEl) onlineEl.textContent = String(onlineCount);
  }

  // ---------------- Active-registry live update ----------------

  const TYPE_TONE = {
    'ADDRESS':      'text-fg-secondary',
    'CALL_PATTERN': 'text-caution-300',
    'BYTECODE':     'text-immune-300',
    'GRAPH':        'text-accent-soft',
  };

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  function escapeAttr(s) { return escapeHtml(s); }

  function fmtMoneyCents(v) {
    const n = Number(v);
    if (!Number.isFinite(n)) return '-';
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function timeAgo(iso) {
    if (!iso) return '-';
    const then = Date.parse(iso);
    if (!Number.isFinite(then)) return '-';
    const sec = Math.max(0, Math.floor((Date.now() - then) / 1000));
    if (sec < 60)        return sec + 's ago';
    if (sec < 3600)      return Math.floor(sec / 60) + 'm ago';
    if (sec < 86400)     return Math.floor(sec / 3600) + 'h ago';
    if (sec < 86400 * 7) return Math.floor(sec / 86400) + 'd ago';
    return new Date(then).toISOString().slice(0, 10);
  }

  function shortHex(hex) {
    if (!hex) return '';
    return '0x' + hex.slice(0, 6) + '…' + hex.slice(-4);
  }

  function renderRegistryRow(r) {
    const typeUpper = String(r.type || '').toUpperCase();
    const typeTone = TYPE_TONE[typeUpper] || 'text-threat-300';
    const reasoning = r.reasoning && r.reasoning.trim() !== '' ? r.reasoning : 'no reasoning recorded';
    const trunc = reasoning.length > 70 ? reasoning.slice(0, 68) + '…' : reasoning;
    const isHexPub = !r.publisher_ens;
    const publisher = r.publisher_ens || shortHex(r.publisher_hex);
    const pubCls = isHexPub
      ? 'font-mono text-[11.5px] text-fg-secondary'
      : 'text-[12.5px] text-fg-secondary';
    const cacheHits = Number(r.cache_hits || 0).toLocaleString('en-US');
    const lastBlock = r.last_block_at ? timeAgo(r.last_block_at) : '-';
    return (
      '<tr data-registry-row="' + escapeAttr(r.imm_id) + '" class="border-b border-ink-line/30 last:border-0 hover:bg-ink-elevated/30 transition-colors group">' +
        '<td class="pl-7 pr-4 py-3"><a href="/antibody/' + escapeAttr(r.imm_id) + '" class="font-mono text-[12.5px] text-fg-primary group-hover:text-accent transition-colors">' + escapeHtml(r.imm_id) + '</a></td>' +
        '<td class="pr-4 py-3"><span class="font-mono text-[10.5px] uppercase tracking-widest2 ' + typeTone + '">' + escapeHtml(typeUpper) + '</span></td>' +
        '<td class="pr-6 py-3 max-w-[320px]"><span class="text-[12.5px] text-fg-secondary truncate inline-block max-w-full" title="' + escapeAttr(reasoning) + '">' + escapeHtml(trunc) + '</span></td>' +
        '<td class="pr-4 py-3"><span class="' + pubCls + '">' + escapeHtml(publisher) + '</span></td>' +
        '<td class="pr-4 py-3 text-right font-mono text-[12px] text-fg-primary tabular-nums">' + cacheHits + '</td>' +
        '<td class="pr-4 py-3 text-right font-mono text-[12px] text-immune-500 tabular-nums">' + fmtMoneyCents(r.value_protected_usd) + '</td>' +
        '<td class="pr-7 py-3 text-right font-mono text-[11px] text-fg-tertiary tabular-nums">' + lastBlock + '</td>' +
      '</tr>'
    );
  }

  function flashRow(tbody, immId) {
    const row = tbody.querySelector('[data-registry-row="' + CSS.escape(immId) + '"]');
    if (!row) return;
    row.style.transition = 'background-color 220ms ease-out';
    row.style.backgroundColor = 'rgba(232, 212, 160, 0.18)';
    setTimeout(function () { row.style.backgroundColor = ''; }, 900);
  }

  function updateRegistry(entries) {
    const tbody = document.querySelector('[data-registry-body]');
    if (!tbody || !Array.isArray(entries)) return;
    const currentIds = Array.from(tbody.querySelectorAll('[data-registry-row]'))
      .map(function (el) { return el.getAttribute('data-registry-row'); });
    const nextIds = entries.map(function (e) { return e.imm_id; });
    const same = currentIds.length === nextIds.length
      && currentIds.every(function (id, i) { return id === nextIds[i]; });
    if (same) return;
    if (entries.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="px-7 py-8 text-center font-mono text-[11.5px] text-fg-dim">No antibodies published yet. Rows will appear as the fleet publishes new threats.</td></tr>';
      return;
    }
    tbody.innerHTML = entries.map(renderRegistryRow).join('');
    const newIds = nextIds.filter(function (id) { return currentIds.indexOf(id) === -1; });
    newIds.forEach(function (id) { flashRow(tbody, id); });
  }

  // ---------------- Poll loop ----------------

  function tick() {
    const url = '/api/v1/dashboard/activity' + (cursor ? '?since=' + encodeURIComponent(cursor) : '');
    fetch(url, { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (data) {
        if (!data) return;
        cursor = data.next_since || cursor;
        const agents = data.agents || [];
        bindAgentMap(agents);
        applyOnlineSet(agents);
        updateAgentList(agents);
        if (window.__dashMap) {
          window.__dashMap.applyEvents({
            checks: data.checks || [],
            blocks: data.blocks || [],
          });
        }
        updateRegistry(data.recent_entries || []);
      })
      .catch(function () { /* swallow: next tick will retry */ });
  }

  function loop() {
    if (document.visibilityState === 'visible') tick();
    setTimeout(loop, 2000);
  }
  // Wait for the map to construct in the DOMContentLoaded handler above.
  setTimeout(loop, 200);
})();
</script>

{/block}
