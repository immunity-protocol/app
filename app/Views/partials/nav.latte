                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M4 6l16 0"/>
                <path d="M4 12l16 0"/>
                <path d="M4 18l16 0"/>
            </svg>
            <svg id="nav-burger-icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M18 6l-12 12"/>
                <path d="M6 6l12 12"/>
