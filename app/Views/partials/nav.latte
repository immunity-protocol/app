            <a href="/publishers" class="px-3 py-3 text-fg-primary hover:bg-ink-elevated/50 rounded-sm transition-colors">Publishers</a>
            <a href="/dashboard"  class="px-3 py-3 text-fg-primary hover:bg-ink-elevated/50 rounded-sm transition-colors">Dashboard</a>
            <a href="/dex"        class="px-3 py-3 text-fg-primary hover:bg-ink-elevated/50 rounded-sm transition-colors">DEX</a>
            <a href="/feeds"      class="px-3 py-3 text-fg-primary hover:bg-ink-elevated/50 rounded-sm transition-colors">Feeds</a>
            <a href="https://docs.immunity.xyz" rel="noopener" class="px-3 py-3 text-fg-primary hover:bg-ink-elevated/50 rounded-sm transition-colors flex items-center justify-between gap-2">
                <span>Docs</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
