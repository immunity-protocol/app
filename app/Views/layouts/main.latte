<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{block title}Immunity{/block}</title>

    {var $siteUrl = 'https://immunity-protocol.com'}
    {var $defaultDescription = 'Decentralized threat intelligence for AI agents. An attack on one is a vaccine for all.'}
    {var $defaultTitle = 'Immunity, decentralized threat intelligence for AI agents'}
    {var $defaultOgImage = $siteUrl . '/assets/og/og-default.png'}

    {* Pages can set $metaTitle / $metaDescription / $metaUrl / $metaImage
       at the top of their template before the layout block is rendered;
       defaults fall back to the protocol-wide tagline below. *}
    {var $metaTitle = $metaTitle ?? $defaultTitle}
    {var $metaDescription = $metaDescription ?? $defaultDescription}
    {var $metaUrl = $metaUrl ?? $siteUrl}
    {var $metaImage = $metaImage ?? $defaultOgImage}

    <meta name="description" content="{$metaDescription}">
    <meta name="author" content="Immunity Protocol">
    <meta name="theme-color" content="#0e0e0d">
    <meta name="color-scheme" content="dark">

    <link rel="canonical" href="{$metaUrl}">

    {* Open Graph (Facebook, LinkedIn, Discord, Slack, etc.) *}
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Immunity">
    <meta property="og:title" content="{$metaTitle}">
    <meta property="og:description" content="{$metaDescription}">
    <meta property="og:url" content="{$metaUrl}">
    <meta property="og:image" content="{$metaImage}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Immunity, decentralized threat intelligence for AI agents">

    {* Twitter card *}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{$metaTitle}">
    <meta name="twitter:description" content="{$metaDescription}">
    <meta name="twitter:image" content="{$metaImage}">

    {* Feed auto-discovery *}
    <link rel="alternate" type="application/rss+xml"  title="Immunity antibodies (RSS)"        href="/feed/antibodies.rss">
    <link rel="alternate" type="application/feed+json" title="Immunity antibodies (JSON Feed)" href="/feed/antibodies.json">
    <link rel="alternate" type="application/atom+xml" title="Immunity antibodies (Atom)"       href="/feed/antibodies.atom">

    {* Organization rich-result schema *}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Immunity Protocol",
        "url": "https://immunity-protocol.com",
        "logo": "https://immunity-protocol.com/assets/images/immunity-mark.png",
        "description": "Decentralized threat intelligence for AI agents.",
        "sameAs": [
            "https://github.com/immunity-protocol"
        ]
    }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400&display=swap">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ink:    { base: '#0e0e0d', surface: '#16161410', sunken: '#0a0a09', elevated: '#1c1c1a', raised: '#252521', line: '#2a2a26', strong: '#3a3a34' },
              fg:     { primary: '#e8e8e3', secondary: '#9a9a92', tertiary: '#5e5e58', dim: '#3e3e38' },
              immune: { 100: '#dceadb', 300: '#a8cfa8', 500: '#7ab87a', 600: '#5e9c5e', 700: '#447844' },
              threat: { 100: '#efd0d0', 300: '#dca0a0', 500: '#c45a5a', 600: '#a44848', 700: '#7e3636' },
              caution:{ 100: '#f0e0c0', 300: '#dfc488', 500: '#d4a04a', 600: '#b58233', 700: '#8a611f' },
              accent: { DEFAULT: '#e8d4a0', soft: '#d8c08c', muted: '#9c8a64' },
              cream:  { base: '#f5f1e8', elevated: '#ede8d9', sunken: '#ece6d4', line: '#d8d0bd', strong: '#b8ad94' },
              parch:  { primary: '#1a1a18', secondary: '#3e3e38', tertiary: '#6a6a62', dim: '#9c9c92' },
            },
            fontFamily: {
              sans:    ['Inter', 'system-ui', 'sans-serif'],
              display: ['Fraunces', 'Georgia', 'serif'],
              mono:    ['"JetBrains Mono"', 'ui-monospace', 'monospace'],
            },
            letterSpacing: {
              tightest: '-0.045em',
              tighter:  '-0.025em',
              widest2:  '0.22em',
            },
            fontSize: {
              '2xs': ['10.5px', { lineHeight: '1.4', letterSpacing: '0.04em' }],
              'micro': ['11px', { lineHeight: '1.4', letterSpacing: '0.18em' }],
            },
            boxShadow: {
              'inset-line': 'inset 0 -1px 0 rgba(232, 232, 227, 0.06)',
              'panel':       '0 0 0 1px rgba(232, 232, 227, 0.05), 0 1px 0 rgba(0, 0, 0, 0.4)',
            },
          }
        }
      };
    </script>

    <link rel="stylesheet" href="{asset('/stylesheets/app.css')}">

    <script>
      // Drives the nav transparent → island states via a single body[data-scrolled] flag.
      (function () {
        const SCROLL_THRESHOLD = 64;
        const update = () => {
          document.body.dataset.scrolled = (window.scrollY > SCROLL_THRESHOLD) ? 'true' : 'false';
        };
        document.addEventListener('DOMContentLoaded', update);
        window.addEventListener('scroll', update, { passive: true });
      })();
    </script>

    <script defer src="https://cloud.umami.is/script.js" data-website-id="e4ff88b3-1387-486b-bfc3-a6996cb0c990"></script>

    {block head}{/block}
</head>
<body class="min-h-full antialiased">
    <div class="min-h-screen flex flex-col bg-ink-base">
        {include '../partials/nav.latte'}
        <main class="flex-1">
            {block content}{/block}
        </main>
        {include '../partials/footer.latte'}
    </div>
</body>
</html>
