{
    "name": "ophelios/immunity-app",
    "description": "Immunity: decentralized threat intelligence for AI agents.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "David Tucker",
            "email": "david.tucker@ophelios.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/zephyrus-framework/core.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/ophelios-studio/php-ethereum-ens.git"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-sodium": "*",
        "ophelios/php-ethereum-ens": "dev-dev",
        "zephyrus-framework/core": "dev-dev"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "phpunit/phpunit": "^11.0",
        "symfony/var-dumper": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "app/Controllers",
            "App\\Models\\": "app/Models"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Tests\\Fixtures\\": "tests/fixtures/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --stderr",
        "test:unit": "vendor/bin/phpunit --testsuite=unit --stderr",
        "test:integration": "vendor/bin/phpunit --testsuite=integration --stderr",
        "indexer": "php bin/indexer.php"
    },
    "config": {
        "sort-packages": true
    }
}
