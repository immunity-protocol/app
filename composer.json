{
    "name": "ophelios/immunity-app",
    "description": "Immunity: decentralized threat intelligence for AI agents.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "David Tucker",
            "email": "david.tucker@ophelios.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../zephyrus2",
            "options": {
                "symlink": false
            }
        }
    ],
    "require": {
        "php": "^8.4",
        "zephyrus-framework/core": "@dev",
        "ext-pdo": "*",
        "ext-intl": "*",
        "ext-sodium": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "phpunit/phpunit": "^11.0",
        "symfony/var-dumper": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "app/Controllers",
            "App\\Models\\": "app/Models"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --stderr",
        "test:unit": "vendor/bin/phpunit --testsuite=unit --stderr",
        "test:integration": "vendor/bin/phpunit --testsuite=integration --stderr",
        "seed": "php bin/seed.php",
        "seed:reset": "php bin/seed.php --reset"
    },
    "config": {
        "sort-packages": true
    }
}
