APP_ENV=dev
APP_DEBUG=true
APP_TIMEZONE=UTC
# APP_CURRENCY=USD

# Security
ENCRYPTION_KEY=

# Database
DB_HOST=immunity_database
DB_PORT=5432
DB_NAME=immunity
DB_USERNAME=dev
DB_PASSWORD=dev

# Moralis API key for token-price lookups in the indexer. Optional in v1
# (without it, value_at_risk_usd stays NULL). Production: `fly secrets set`.
MORALIS_API_KEY=

# Mirror chain RPCs (read by both indexer and relayer). Empty values cause
# the corresponding chain's poller / relayer to skip with a warning.
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# Relayer hot wallet keys, one per chain. The wallet must be authorized on
# the destination Mirror via setRelayer(addr, true). NEVER commit a real key.
RELAYER_PRIVATE_KEY_SEPOLIA=
RELAYER_PRIVATE_KEY_BASE_SEPOLIA=

# Relayer behavior knobs (defaults shown). Bridge timeout governs how long
# the PHP wrapper waits for scripts/mirror-send.mjs per tx.
RELAYER_POLL_INTERVAL_MS=2000
RELAYER_MAX_RETRIES=5
RELAYER_BATCH_SIZE=10
RELAYER_BACKOFF_BASE_MS=5000
RELAYER_REAP_INTERVAL_SEC=60
RELAYER_REAP_STALE_SEC=300
RELAYER_BRIDGE_TIMEOUT_SEC=90
RELAYER_MEMORY_CEILING_MB=256

# Optional: override the path to config/mirror-network.json (e.g. for tests).
# MIRROR_NETWORK_FILE=
